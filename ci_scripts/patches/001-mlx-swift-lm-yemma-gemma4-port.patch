+// Copyright © 2026 Apple Inc.
+
+import CoreGraphics
+import Foundation
+import ImageIO
+import MLX
+import MLXLMCommon
+import XCTest
+import UniformTypeIdentifiers
+
+@testable import MLXVLM
+
+private final class RecordingGemma4Tokenizer: Tokenizer, @unchecked Sendable {
+    struct ApplyChatTemplateCall: Sendable {
+        let messages: [[String: any Sendable]]
+        let toolCount: Int
+        let additionalContext: [String: any Sendable]?
+        let additionalContextCount: Int
+    }
+
+    private(set) var applyChatTemplateCalls: [ApplyChatTemplateCall] = []
+    private(set) var lastDecodedTokenIds: [Int] = []
+    private(set) var lastSkipSpecialTokens: Bool?
+
+    private let tokenMap: [String: Int] = [
+        "<bos>": 1,
+        "<eos>": 2,
+        "<unk>": 3,
+    ]
+
+    func encode(text: String, addSpecialTokens: Bool) -> [Int] {
+        addSpecialTokens ? [1, 11, 2] : [11]
+    }
+
+    func decode(tokenIds: [Int], skipSpecialTokens: Bool) -> String {
+        lastSkipSpecialTokens = skipSpecialTokens
+        lastDecodedTokenIds = skipSpecialTokens ? tokenIds.filter { $0 != 2 } : tokenIds
+        return lastDecodedTokenIds.map(String.init).joined(separator: " ")
+    }
+
+    func convertTokenToId(_ token: String) -> Int? {
+        tokenMap[token]
+    }
+
+    func convertIdToToken(_ id: Int) -> String? {
+        tokenMap.first(where: { $0.value == id })?.key
+    }
+
+    var bosToken: String? { "<bos>" }
+    var eosToken: String? { "<eos>" }
+    var unknownToken: String? { "<unk>" }
+
+    func applyChatTemplate(
+        messages: [[String: any Sendable]],
+        tools: [[String: any Sendable]]?,
+        additionalContext: [String: any Sendable]?
+    ) throws -> [Int] {
+        applyChatTemplateCalls.append(
+            .init(
+                messages: messages,
+                toolCount: tools?.count ?? 0,
+                additionalContext: additionalContext,
+                additionalContextCount: additionalContext?.count ?? 0
+            )
+        )
+        return [101, 102, 103]
+    }
+}
+
+final class Gemma4ParityTests: XCTestCase {
+    private func makeConfiguration() -> Gemma4ProcessorConfiguration {
+        Gemma4ProcessorConfiguration(
+            processorClass: "Gemma4Processor",
+            imageSeqLength: 280,
+            audioSeqLength: 750,
+            audioMsPerToken: 40,
+            imageProcessor: Gemma4ImageProcessorConfiguration(
+                imageProcessorType: "Gemma4ImageProcessor",
+                doConvertRgb: true,
+                doNormalize: false,
+                doRescale: true,
+                doResize: true,
+                imageMean: [0.0, 0.0, 0.0],
+                imageStd: [1.0, 1.0, 1.0],
+                imageSeqLength: 280,
+                maxSoftTokens: 280,
+                patchSize: 16,
+                poolingKernelSize: 3,
+                resample: 3,
+                rescaleFactor: 1.0 / 255.0,
+                size: .init(height: 224, width: 224)
+            )
+        )
+    }
+
+    private func makeProcessor(tokenizer: any Tokenizer) -> Gemma4Processor {
+        Gemma4Processor(makeConfiguration(), tokenizer: tokenizer)
+    }
+
+    private func textContent(of message: [String: any Sendable]) -> String? {
+        if let content = message["content"] as? String {
+            return content
+        }
+        if let content = message["content"] as? [[String: String]] {
+            if let first = content.first {
+                return first["text"] ?? first["content"]
+            }
+        }
+        return nil
+    }
+
+    private func contentEntries(of message: [String: any Sendable]) -> [[String: String]]? {
+        if let content = message["content"] as? [[String: String]] {
+            return content
+        }
+        return nil
+    }
+
+    private func makePNGImageFile(width: Int, height: Int) throws -> URL {
+        let tempURL = URL(fileURLWithPath: NSTemporaryDirectory())
+            .appending(path: "\(UUID().uuidString).png")
+
+        let colorSpace = CGColorSpaceCreateDeviceRGB()
+        let bitmapInfo = CGImageAlphaInfo.premultipliedLast.rawValue
+        guard
+            let context = CGContext(
+                data: nil,
+                width: width,
+                height: height,
+                bitsPerComponent: 8,
+                bytesPerRow: width * 4,
+                space: colorSpace,
+                bitmapInfo: bitmapInfo
+            )
+        else {
+            throw XCTSkip("Unable to create image context in this test environment.")
+        }
+
+        context.setFillColor(CGColor(red: 0.12, green: 0.45, blue: 0.88, alpha: 1.0))
+        context.fill(CGRect(x: 0, y: 0, width: width, height: height))
+
+        guard let image = context.makeImage() else {
+            throw XCTSkip("Unable to create test image.")
+        }
+
+        guard
+            let destination = CGImageDestinationCreateWithURL(
+                tempURL as CFURL, UTType.png.identifier as CFString, 1, nil)
+        else {
+            throw XCTSkip("Unable to create image destination.")
+        }
+
+        CGImageDestinationAddImage(destination, image, nil)
+        guard CGImageDestinationFinalize(destination) else {
+            throw XCTSkip("Unable to write test image.")
+        }
+
+        return tempURL
+    }
+
+    private func assertAcceptancePromptScaffolding(
+        _ prompt: String,
+        file: StaticString = #filePath,
+        line: UInt = #line
+    ) async throws {
+        try requireMLXMetalLib()
+
+        let tokenizer = RecordingGemma4Tokenizer()
+        let processor = makeProcessor(tokenizer: tokenizer)
+        let input = UserInput(prompt: prompt)
+
+        let prepared = try await processor.prepare(input: input)
+
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls.count, 1, file: file, line: line)
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls[0].toolCount, 0, file: file, line: line)
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls[0].additionalContextCount, 1, file: file, line: line)
+        XCTAssertEqual(
+            tokenizer.applyChatTemplateCalls[0].additionalContext?["enable_thinking"] as? Bool,
+            false,
+            file: file,
+            line: line
+        )
+
+        let messages = tokenizer.applyChatTemplateCalls[0].messages
+        XCTAssertEqual(messages.count, 1, file: file, line: line)
+        XCTAssertEqual(messages[0]["role"] as? String, "user", file: file, line: line)
+        XCTAssertEqual(textContent(of: messages[0]), prompt, file: file, line: line)
+        XCTAssertEqual(prepared.text.tokens.shape, [1, 3], file: file, line: line)
+        XCTAssertNil(prepared.image, file: file, line: line)
+    }
+
+    func testAcceptanceHelloPromptScaffoldingUsesSingleUserMessage() async throws {
+        try await assertAcceptancePromptScaffolding("Say exactly: Hello from Gemma 4.")
+    }
+
+    func testAcceptanceTwoPlusTwoPromptScaffoldingUsesSingleUserMessage() async throws {
+        try await assertAcceptancePromptScaffolding("What is 2 + 2?")
+    }
+
+    func testAcceptanceImagePromptBuildsMultimodalContract() async throws {
+        try requireMLXMetalLib()
+
+        let tokenizer = RecordingGemma4Tokenizer()
+        let processor = makeProcessor(tokenizer: tokenizer)
+        let imageURL = try makePNGImageFile(width: 48, height: 32)
+        defer { try? FileManager.default.removeItem(at: imageURL) }
+
+        let input = UserInput(
+            chat: [
+                .system("You are a helpful assistant."),
+                .user("Describe this image.", images: [.url(imageURL)]),
+            ]
+        )
+        XCTAssertEqual(input.images.count, 1)
+
+        let prepared = try await processor.prepare(input: input)
+
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls.count, 1)
+        let messages = tokenizer.applyChatTemplateCalls[0].messages
+        XCTAssertEqual(messages.map { $0["role"] as? String }, ["system", "user"])
+        XCTAssertEqual(textContent(of: messages[0]), "You are a helpful assistant.")
+        XCTAssertEqual(textContent(of: messages[1]), "Describe this image.")
+
+        let content = try XCTUnwrap(contentEntries(of: messages[1]))
+        XCTAssertEqual(content.count, 2)
+        XCTAssertEqual(content[0]["type"], "image")
+        XCTAssertEqual(content[1]["type"], "text")
+        XCTAssertEqual(content[1]["text"], "Describe this image.")
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls[0].additionalContextCount, 1)
+        XCTAssertEqual(
+            tokenizer.applyChatTemplateCalls[0].additionalContext?["enable_thinking"] as? Bool,
+            false
+        )
+        XCTAssertEqual(prepared.text.tokens.shape[0], 1)
+        XCTAssertGreaterThan(prepared.text.tokens.shape[1], 3)
+        XCTAssertNotNil(prepared.image)
+        XCTAssertEqual(prepared.image?.pixels.shape[0], 1)
+        XCTAssertEqual(prepared.image?.pixels.shape[1], 3)
+        XCTAssertEqual(prepared.image?.frames?.count, 1)
+    }
+
+    func testExplicitThinkingOverrideSurvivesIntoChatTemplateContext() async throws {
+        try requireMLXMetalLib()
+
+        let tokenizer = RecordingGemma4Tokenizer()
+        let processor = makeProcessor(tokenizer: tokenizer)
+        let input = UserInput(
+            prompt: "Describe the image.",
+            additionalContext: ["enable_thinking": true]
+        )
+
+        _ = try await processor.prepare(input: input)
+
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls.count, 1)
+        XCTAssertEqual(tokenizer.applyChatTemplateCalls[0].additionalContextCount, 1)
+        XCTAssertEqual(
+            tokenizer.applyChatTemplateCalls[0].additionalContext?["enable_thinking"] as? Bool,
+            true
+        )
+    }
+
+    func testDecodeDefaultsMatchSkipSpecialTokensFalse() {
+        let tokenizer = RecordingGemma4Tokenizer()
+        let asProtocol: any Tokenizer = tokenizer
+
+        _ = asProtocol.decode(tokenIds: [1, 2, 3])
+        XCTAssertEqual(tokenizer.lastSkipSpecialTokens, false)
+        XCTAssertEqual(tokenizer.lastDecodedTokenIds, [1, 2, 3])
+
+        _ = asProtocol.decode(tokenIds: [1, 2, 3], skipSpecialTokens: true)
+        XCTAssertEqual(tokenizer.lastSkipSpecialTokens, true)
+        XCTAssertEqual(tokenizer.lastDecodedTokenIds, [1, 3])
+    }
+
+    func testTokenTraceFormatIsStable() {
+        let trace =
+            "[gemma4-token-trace] mode=text-only roles=user template=default add_generation_prompt=true add_special_tokens=false skip_special_tokens=false prompt_tokens=[101,102,103]"
+
+        XCTAssertTrue(trace.contains("mode=text-only"))
+        XCTAssertTrue(trace.contains("roles=user"))
+        XCTAssertTrue(trace.contains("add_generation_prompt=true"))
+        XCTAssertTrue(trace.contains("skip_special_tokens=false"))
+    }
+
+    func testStreamingDetokenizerCanSkipSpecialTokens() {
+        let tokenizer = RecordingGemma4Tokenizer()
+        var detokenizer = NaiveStreamingDetokenizer(
+            tokenizer: tokenizer,
+            skipSpecialTokens: true
+        )
+
+        detokenizer.append(token: 1)
+        detokenizer.append(token: 2)
+        detokenizer.append(token: 3)
+        _ = detokenizer.next()
+
+        XCTAssertEqual(tokenizer.lastSkipSpecialTokens, true)
+        XCTAssertEqual(tokenizer.lastDecodedTokenIds, [1, 3])
+    }
+}
