+
+    func testPreparedEmbeddingsMatchTokenPathWhenPreScaled() throws {
+        try requireMLXMetalLib()
+
+        let config = makeTinyConfig()
+        let model = Gemma4TextModel(config)
+        let inputIds = MLXArray([1, 2, 3, 4])[.newAxis, .ellipsis]
+        let preScaledEmbeddings = model.embedTokens(inputIds) * pow(Float(config.hiddenSize), 0.5)
+
+        let logitsFromTokens = model(
+            inputs: inputIds,
+            cache: nil,
+            inputEmbeddings: nil,
+            perLayerInputs: nil
+        )
