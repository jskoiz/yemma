+private final class Gemma4ProportionalRoPE: Module, OffsetLayer, ArrayOffsetLayer {
+    let dimensions: Int
+    let traditional: Bool
+    let freqs: MLXArray
+
+    init(
+        dimensions: Int,
+        rotatedDimensions: Int,
+        traditional: Bool = false,
+        base: Float = 10_000.0,
+        factor: Float = 1.0
+    ) {
+        precondition(rotatedDimensions <= dimensions, "rotatedDimensions must be <= dimensions")
+        self.dimensions = dimensions
+        self.traditional = traditional
+
+        let exponents =
+            MLXArray(stride(from: 0, to: rotatedDimensions, by: 2)).asType(.float32)
+            / Float(dimensions)
+        let rotatedFreqs = factor * pow(base, exponents)
+        let fillerLength = max((dimensions - rotatedDimensions) / 2, 0)
+        let filler = MLXArray(Array(repeating: Float.infinity, count: fillerLength))
+        self.freqs = concatenated([rotatedFreqs, filler], axis: 0)
+
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray, offset: Int = 0) -> MLXArray {
+        MLXFast.RoPE(
+            x,
+            dimensions: dimensions,
+            traditional: traditional,
+            base: nil,
+            scale: 1.0,
+            offset: offset,
+            freqs: freqs
+        )
+    }
+
+    func callAsFunction(_ x: MLXArray, offset: MLXArray) -> MLXArray {
+        MLXFast.RoPE(
+            x,
+            dimensions: dimensions,
+            traditional: traditional,
+            base: nil,
+            scale: 1.0,
+            offset: offset,
+            freqs: freqs
+        )
+    }
+
+    override func updateMissing(
+        parameter: String,
+        verify: VerifyUpdate,
+        path: [String],
+        modulePath: [String]
+    ) throws {
+        if parameter == "freqs" {
+            return
+        }
+
+        try super.updateMissing(
+            parameter: parameter,
+            verify: verify,
+            path: path,
+            modulePath: modulePath
+        )
+    }
+}
