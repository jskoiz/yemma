+// MARK: - VLM Shell
+
+public final class Gemma4<TextBackbone: Gemma4TextBackbone>: Module, VLMModel,
+    KVCacheDimensionProvider
+{
+    @ModuleInfo(key: "vision_tower") private var visionTower: Gemma4VisionModel
+    @ModuleInfo(key: "language_model") private var languageModel: TextBackbone
+    @ModuleInfo(key: "embed_vision") private var embedVision: Gemma4MultimodalEmbedder
+
+    public let config: Gemma4Configuration
+
+    public var vocabularySize: Int { config.vocabularySize }
+    public var kvHeads: [Int] { languageModel.kvHeads }
+    public var loraLayers: [Module] { languageModel.loraLayers + [visionTower, embedVision] }
+    public var quantPredicate: (String, Module) -> (groupSize: Int, bits: Int, mode: QuantizationMode)?
+    {
+        { _, module in
+            guard module is Quantizable else {
+                return nil
+            }
+            return self.config.quantization?.asTuple
+                ?? self.config.textConfiguration.quantization?.asTuple
+                ?? (64, 4, .affine)
+        }
+    }
+
+    public init(_ config: Gemma4Configuration, languageModel: TextBackbone) {
+        self.config = config
+        self._visionTower.wrappedValue = Gemma4VisionModel(config: config.visionConfiguration)
+        self._languageModel.wrappedValue = languageModel
+        self._embedVision.wrappedValue = Gemma4MultimodalEmbedder(
+            embeddingDim: config.visionConfiguration.hiddenSize,
+            textHiddenSize: config.textConfiguration.hiddenSize,
+            eps: config.visionConfiguration.rmsNormEps
+        )
+        super.init()
+    }
+
+    public func newCache(parameters: GenerateParameters?) -> [KVCache] {
+        languageModel.newCache(parameters: parameters)
+    }
+
+    public func encodeImage(_ pixelValues: MLXArray) -> MLXArray {
+        embedVision(visionTower(pixelValues))
+    }
+
+    func getInputEmbeddings(
+        inputIds: MLXArray, pixelValues: MLXArray? = nil, cachedImageFeatures: MLXArray? = nil
+    ) throws -> Gemma4InputEmbeddingsFeatures {
+        var inputsEmbeds = languageModel.embedTokens(inputIds)
+        inputsEmbeds = inputsEmbeds * pow(Float(config.textConfiguration.hiddenSize), 0.5)
+
+        var perLayerInputs: MLXArray?
+        if config.textConfiguration.hiddenSizePerLayerInput > 0 {
+            let imageMaskIds = inputIds .== MLXArray(config.imageTokenId)
+            let audioMaskIds = inputIds .== MLXArray(config.audioTokenId)
+            let maskedInputIds = MLX.where(
+                MLX.logicalOr(
+                    imageMaskIds,
+                    audioMaskIds
+                ),
+                MLXArray.zeros(like: inputIds),
+                inputIds
+            )
+            perLayerInputs = languageModel.perLayerInputs(maskedInputIds)
+        }
+
+        guard pixelValues != nil || cachedImageFeatures != nil else {
+            return Gemma4InputEmbeddingsFeatures(
+                inputsEmbeds: inputsEmbeds, perLayerInputs: perLayerInputs)
+        }
+
+        let imageFeatures =
+            if let cachedImageFeatures {
+                cachedImageFeatures.asType(inputsEmbeds.dtype)
+            } else if let pixelValues {
+                encodeImage(pixelValues).asType(inputsEmbeds.dtype)
+            } else {
+                MLXArray.zeros([1, 0, config.textConfiguration.hiddenSize], dtype: inputsEmbeds.dtype)
+            }
+
+        let imageMask = inputIds .== MLXArray(config.imageTokenId)
+        let imageMaskExpanded = broadcast(
+            expandedDimensions(imageMask, axis: -1), to: inputsEmbeds.shape)
+
+        let scattered = try maskedScatter(
+            inputTensor: inputsEmbeds, mask: imageMaskExpanded, source: imageFeatures)
+        return Gemma4InputEmbeddingsFeatures(inputsEmbeds: scattered, perLayerInputs: perLayerInputs)
+    }
+
+    public func prepare(_ input: LMInput, cache: [any KVCache], windowSize: Int?) throws
+        -> PrepareResult
+    {
+        guard let imagePixels = input.image?.pixels else {
+            let convertedCache = cache.compactMap { $0 as KVCache }
+            precondition(
+                input.text.tokens.ndim == 2,
+                "Gemma4 text-only prepare expected rank-2 tokens [batch, seq], got \(input.text.tokens.shape)"
+            )
+            let logits = languageModel(input.text.tokens, cache: convertedCache)
+            return .logits(LMOutput(logits: logits))
+        }
+
+        precondition(
+            input.text.tokens.ndim == 2,
+            "Gemma4 multimodal prepare expected rank-2 tokens [batch, seq], got \(input.text.tokens.shape)"
+        )
+        let pixels =
+            if imagePixels.ndim == 3 || imagePixels.ndim == 4 {
+                imagePixels
+            } else {
+                throw Gemma4VLMError.unsupportedImageRank(imagePixels.ndim)
+            }
+
+        let embeddings = try getInputEmbeddings(
+            inputIds: input.text.tokens, pixelValues: pixels)
+        let convertedCache = cache.compactMap { $0 as KVCache }
+        precondition(
+            embeddings.inputsEmbeds.ndim == 3,
+            "Gemma4 multimodal prepare expected rank-3 decoder embeddings [batch, seq, hidden], got \(embeddings.inputsEmbeds.shape)"
+        )
+        let output = languageModel(
+            inputIds: nil,
+            cache: convertedCache,
+            inputsEmbeds: embeddings.inputsEmbeds,
+            perLayerInputs: embeddings.perLayerInputs
+        )
+        return .logits(output)
+    }
+
+    public func callAsFunction(_ inputs: MLXArray, cache: [any KVCache]?) -> MLXArray {
+        languageModel(inputs, cache: cache?.compactMap { $0 as KVCache })
+    }
+
+    private func hasQuantizedWeights(layerPath: String, in weights: [String: MLXArray]) -> Bool {
+        let scalesKey = "\(layerPath).scales"
+        let biasesKey = "\(layerPath).biases"
+        let weightKey = "\(layerPath).weight"
+        return weights[scalesKey] != nil
+            && weights[biasesKey] != nil
+            && weights[weightKey]?.dtype == .uint32
+    }
+
+    public func sanitize(weights: [String: MLXArray]) -> [String: MLXArray] {
+        let languageWeights = Dictionary(
+            uniqueKeysWithValues: weights.filter { key, _ in
+                key.hasPrefix("model.language_model.")
+                    || key.hasPrefix("language_model.")
+                    || key.hasPrefix("lm_head.")
+                    || key.hasPrefix("model.lm_head.")
+            })
+        let sanitizedLanguageWeights = languageModel.sanitize(
+            weights: languageWeights, quantization: config.quantization)
+        var remapped: [String: MLXArray] = [:]
+
+        for (key, value) in sanitizedLanguageWeights {
+            var normalizedKey = key
+            if normalizedKey.contains("audio_tower") || normalizedKey.contains("embed_audio") {
+                continue
+            }
+            if normalizedKey.contains("rotary_emb.inv_freq") || normalizedKey.contains("rotary_emb")
+            {
+                continue
+            }
+            if normalizedKey.hasPrefix("model.language_model.") {
+                normalizedKey = String(normalizedKey.dropFirst("model.language_model.".count))
+            } else if normalizedKey.hasPrefix("language_model.") {
+                normalizedKey = String(normalizedKey.dropFirst("language_model.".count))
+            }
+            let newKey: String
+            if normalizedKey.hasPrefix("model.") || normalizedKey.hasPrefix("lm_head.") {
+                newKey = "language_model.\(normalizedKey)"
+            } else {
+                newKey = "language_model.model.\(normalizedKey)"
+            }
+            remapped[newKey] = value
+        }
+
+        for (key, value) in weights {
+            if key.contains("audio_tower") || key.contains("embed_audio") {
+                continue
+            }
+            if key.contains("rotary_emb.inv_freq") || key.contains("rotary_emb") {
+                continue
+            }
+            if key.hasPrefix("model.language_model.")
+                || key.hasPrefix("language_model.")
+                || key.hasPrefix("lm_head.")
+                || key.hasPrefix("model.lm_head.")
+            {
+                continue
+            }
+            if !config.visionConfiguration.useClippedLinears,
+                key.contains("vision_tower"),
+                key.contains("input_min") || key.contains("input_max")
+                    || key.contains("output_min") || key.contains("output_max")
+            {
+                continue
+            }
+
+            var newKey = key
+            if newKey.hasPrefix("model.") {
+                newKey = String(newKey.dropFirst("model.".count))
+            }
+            remapped[newKey] = value
+        }
+
+        if remapped["vision_tower.std_bias"] == nil {
+            remapped["vision_tower.std_bias"] = MLXArray.zeros(
+                [config.visionConfiguration.hiddenSize], dtype: .float32)
+        }
+        if remapped["vision_tower.std_scale"] == nil {
+            remapped["vision_tower.std_scale"] = MLXArray.ones(
+                [config.visionConfiguration.hiddenSize], dtype: .float32)
+        }
+
+        let hasQuantizedParameters = remapped.contains { key, value in
+            key.hasSuffix(".weight") && value.dtype == .uint32
+        }
+
+        if hasQuantizedParameters {
+            let defaultQuantization =
+                config.quantization?.asTuple
+                ?? config.textConfiguration.quantization?.asTuple
+                ?? (64, 4, QuantizationMode.affine)
+            quantize(model: self) { [quantPredicate] path, module in
+                guard hasQuantizedWeights(layerPath: path, in: remapped) else {
+                    return nil
+                }
+                return quantPredicate(path, module) ?? defaultQuantization
+            }
+        }
+
+        return remapped
+    }
+}
+
+public extension Gemma4 where TextBackbone == Gemma4TextModel {
+    convenience init(_ config: Gemma4Configuration) {
+        self.init(config, languageModel: Gemma4TextModel(config.textConfiguration))
+    }
+}
