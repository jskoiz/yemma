+// Copyright © 2026 Apple Inc.
+
+import CoreImage
+import Foundation
+import MLX
+import MLXLMCommon
+
+public struct Gemma4ImageSize: Codable, Sendable, Equatable {
+    public let height: Int
+    public let width: Int
+
+    public init(height: Int, width: Int) {
+        self.height = height
+        self.width = width
+    }
+
+    public var cgSize: CGSize {
+        CGSize(width: width, height: height)
+    }
+}
+
+public struct Gemma4ImageProcessorConfiguration: Codable, Sendable {
+    public let imageProcessorType: String?
+    public let doConvertRgb: Bool
+    public let doNormalize: Bool
+    public let doRescale: Bool
+    public let doResize: Bool
+    public let imageMean: [CGFloat]
+    public let imageStd: [CGFloat]
+    public let imageSeqLength: Int?
+    public let maxSoftTokens: Int?
+    public let patchSize: Int
+    public let poolingKernelSize: Int
+    public let resample: Int?
+    public let rescaleFactor: Float
+    public let size: Gemma4ImageSize
+
+    public init(
+        imageProcessorType: String? = nil,
+        doConvertRgb: Bool = true,
+        doNormalize: Bool,
+        doRescale: Bool,
+        doResize: Bool,
+        imageMean: [CGFloat],
+        imageStd: [CGFloat],
+        imageSeqLength: Int? = nil,
+        maxSoftTokens: Int? = nil,
+        patchSize: Int,
+        poolingKernelSize: Int,
+        resample: Int? = nil,
+        rescaleFactor: Float,
+        size: Gemma4ImageSize
+    ) {
+        self.imageProcessorType = imageProcessorType
+        self.doConvertRgb = doConvertRgb
+        self.doNormalize = doNormalize
+        self.doRescale = doRescale
+        self.doResize = doResize
+        self.imageMean = imageMean
+        self.imageStd = imageStd
+        self.imageSeqLength = imageSeqLength
+        self.maxSoftTokens = maxSoftTokens
+        self.patchSize = patchSize
+        self.poolingKernelSize = poolingKernelSize
+        self.resample = resample
+        self.rescaleFactor = rescaleFactor
+        self.size = size
+    }
+
+    public var imageMeanTuple: (CGFloat, CGFloat, CGFloat) {
+        (imageMean[0], imageMean[1], imageMean[2])
+    }
+
+    public var imageStdTuple: (CGFloat, CGFloat, CGFloat) {
+        (imageStd[0], imageStd[1], imageStd[2])
+    }
+
+    public var softTokenBudget: Int {
+        maxSoftTokens ?? imageSeqLength ?? 280
+    }
+
+    public var maxPatches: Int {
+        softTokenBudget * poolingKernelSize * poolingKernelSize
+    }
+
+    public var sideMultiple: Int {
+        patchSize * poolingKernelSize
+    }
+
+    enum CodingKeys: String, CodingKey {
+        case imageProcessorType = "image_processor_type"
+        case doConvertRgb = "do_convert_rgb"
+        case doNormalize = "do_normalize"
+        case doRescale = "do_rescale"
+        case doResize = "do_resize"
+        case imageMean = "image_mean"
+        case imageStd = "image_std"
+        case imageSeqLength = "image_seq_length"
+        case maxSoftTokens = "max_soft_tokens"
+        case patchSize = "patch_size"
+        case poolingKernelSize = "pooling_kernel_size"
+        case resample
+        case rescaleFactor = "rescale_factor"
+        case size
+    }
+}
+
+public struct Gemma4ProcessorConfiguration: Codable, Sendable {
+    public let processorClass: String
+    public let imageSeqLength: Int
+    public let audioSeqLength: Int?
+    public let audioMsPerToken: Int?
+    public let imageProcessor: Gemma4ImageProcessorConfiguration
+
+    public init(
+        processorClass: String,
+        imageSeqLength: Int,
+        audioSeqLength: Int? = nil,
+        audioMsPerToken: Int? = nil,
+        imageProcessor: Gemma4ImageProcessorConfiguration
+    ) {
+        self.processorClass = processorClass
+        self.imageSeqLength = imageSeqLength
+        self.audioSeqLength = audioSeqLength
+        self.audioMsPerToken = audioMsPerToken
+        self.imageProcessor = imageProcessor
+    }
+
+    enum CodingKeys: String, CodingKey {
+        case processorClass = "processor_class"
+        case imageSeqLength = "image_seq_length"
+        case audioSeqLength = "audio_seq_length"
+        case audioMsPerToken = "audio_ms_per_token"
+        case imageProcessor = "image_processor"
+    }
+
+    public init(from decoder: any Decoder) throws {
+        let container = try decoder.container(keyedBy: CodingKeys.self)
+
+        self.processorClass = try container.decode(String.self, forKey: .processorClass)
+        self.audioSeqLength = try container.decodeIfPresent(Int.self, forKey: .audioSeqLength)
+        self.audioMsPerToken = try container.decodeIfPresent(Int.self, forKey: .audioMsPerToken)
+
+        if let nestedImageProcessor = try container.decodeIfPresent(
+            Gemma4ImageProcessorConfiguration.self, forKey: .imageProcessor)
+        {
+            self.imageProcessor = nestedImageProcessor
+        } else {
+            self.imageProcessor = try Gemma4ImageProcessorConfiguration(from: decoder)
+        }
+
+        self.imageSeqLength =
+            try container.decodeIfPresent(Int.self, forKey: .imageSeqLength)
+            ?? imageProcessor.imageSeqLength
+            ?? imageProcessor.softTokenBudget
+    }
+}
+
+struct Gemma4SpecialTokens: Sendable, Equatable {
+    static let fallbackImageTokenId = 258880
+    static let fallbackBoiTokenId = 255999
+    static let fallbackEoiTokenId = 258882
+
+    let imageTokenId: Int
+    let boiTokenId: Int
+    let eoiTokenId: Int
+
+    init(tokenizer: any Tokenizer) {
+        self.imageTokenId = tokenizer.convertTokenToId("<|image|>") ?? Self.fallbackImageTokenId
+        self.boiTokenId = tokenizer.convertTokenToId("<|image>") ?? Self.fallbackBoiTokenId
+        self.eoiTokenId = tokenizer.convertTokenToId("<image|>") ?? Self.fallbackEoiTokenId
+    }
+}
+
+public struct Gemma4MessageGenerator: MessageGenerator {
+    public init() {}
+
+    public func generate(message: Chat.Message) -> MLXLMCommon.Message {
+        switch message.role {
+        case .system:
+            return [
+                "role": message.role.rawValue,
+                "content": message.content,
+            ]
+
+        case .assistant, .tool:
+            return [
+                "role": message.role.rawValue,
+                "content": message.content,
+            ]
+
+        case .user:
+            let content: [[String: String]] =
+                message.images.map { _ in ["type": "image"] }
+                + [["type": "text", "text": message.content]]
+                + message.videos.map { _ in ["type": "video"] }
+
+            return [
+                "role": message.role.rawValue,
+                "content": content,
+            ]
+        }
+    }
+}
+
+public struct Gemma4Processor: UserInputProcessor {
+    struct PreparedImage {
+        let pixels: MLXArray
+        let frame: THW
+        let softTokenCount: Int
+    }
+
+    private enum PromptRoute: String {
+        case textOnly = "text-only"
+        case multimodal = "multimodal"
+    }
+
+    public let configuration: Gemma4ProcessorConfiguration
+    let tokenizer: any Tokenizer
+    let specialTokens: Gemma4SpecialTokens
+
+    public init(_ configuration: Gemma4ProcessorConfiguration, tokenizer: any Tokenizer) {
+        self.configuration = configuration
+        self.tokenizer = tokenizer
+        self.specialTokens = Gemma4SpecialTokens(tokenizer: tokenizer)
+    }
+
+    private func chatTemplateContext(
+        additionalContext: [String: any Sendable]?
+    ) -> [String: any Sendable] {
+        var context = additionalContext ?? [:]
+        if context["enable_thinking"] == nil {
+            context["enable_thinking"] = false
+        }
+        return context
+    }
+
+    private func normalizeLeadingTemplateWhitespace(_ tokens: [Int]) -> [Int] {
+        guard tokens.count > 1,
+            let bosToken = tokenizer.bosToken,
+            let bosTokenId = tokenizer.convertTokenToId(bosToken),
+            tokens[0] == bosTokenId
+        else {
+            return tokens
+        }
+
+        var firstContentIndex = 1
+        while firstContentIndex < tokens.count {
+            let piece = tokenizer.decode(tokenIds: [tokens[firstContentIndex]], skipSpecialTokens: false)
+            guard piece.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty else {
+                break
+            }
+            firstContentIndex += 1
+        }
+
+        guard firstContentIndex > 1, firstContentIndex < tokens.count else {
+            return tokens
+        }
+
+        let firstContent = tokenizer.decode(
+            tokenIds: [tokens[firstContentIndex]],
+            skipSpecialTokens: false
+        )
+        guard firstContent.contains("<|turn>") else {
+            return tokens
+        }
+
+        return [tokens[0]] + Array(tokens[firstContentIndex...])
+    }
+
+    #if DEBUG
+        private var isDebugTokenTraceEnabled: Bool {
+            ProcessInfo.processInfo.environment["GEMMA4_DEBUG_TOKEN_TRACE"] == "1"
+        }
+
+        private func debugParityTrace(
+            route: PromptRoute,
+            roles: [String],
+            templateTokens: [Int],
+            expandedTokens: [Int]? = nil
+        ) {
+            guard isDebugTokenTraceEnabled else {
+                return
+            }
+
+            let finalTokens = expandedTokens ?? templateTokens
+            let preview = finalTokens.prefix(24).map(String.init).joined(separator: ",")
+            let roleList = roles.joined(separator: ",")
+            print(
+                "[gemma4-token-trace]",
+                "mode=\(route.rawValue)",
+                "roles=\(roleList)",
+                "template=checkpoint",
+                "add_generation_prompt=true",
+                "add_special_tokens=false",
+                "skip_special_tokens=false",
+                "template_token_count=\(templateTokens.count)",
+                "final_token_count=\(finalTokens.count)",
+                "prompt_tokens=[\(preview)]"
+            )
+        }
+    #endif
+
+    func resizedSize(for inputSize: CGSize) throws -> CGSize {
+        let imageConfiguration = configuration.imageProcessor
+        let originalHeight = max(Int(inputSize.height.rounded()), 1)
+        let originalWidth = max(Int(inputSize.width.rounded()), 1)
+
+        guard imageConfiguration.doResize else {
+            return CGSize(width: originalWidth, height: originalHeight)
+        }
+
+        let sideMultiple = imageConfiguration.sideMultiple
+        let targetPixels =
+            Double(imageConfiguration.maxPatches)
+            * Double(imageConfiguration.patchSize * imageConfiguration.patchSize)
+        let currentPixels = Double(originalHeight * originalWidth)
+        let factor = Foundation.sqrt(targetPixels / currentPixels)
+
+        var targetHeight =
+            Int(Foundation.floor((factor * Double(originalHeight)) / Double(sideMultiple)))
+            * sideMultiple
+        var targetWidth =
+            Int(Foundation.floor((factor * Double(originalWidth)) / Double(sideMultiple)))
+            * sideMultiple
+
+        if targetHeight == 0, targetWidth == 0 {
+            throw VLMError.imageProcessingFailure("Attempted to resize to 0x0.")
+        }
+
+        let maxSideLength =
+            (imageConfiguration.maxPatches
+                / (imageConfiguration.poolingKernelSize * imageConfiguration.poolingKernelSize))
+            * sideMultiple
+
+        if targetHeight == 0 {
+            targetHeight = sideMultiple
+            targetWidth = min(
+                Int(Foundation.floor(Double(originalWidth) / Double(originalHeight)))
+                    * sideMultiple,
+                maxSideLength
+            )
+        } else if targetWidth == 0 {
+            targetWidth = sideMultiple
+            targetHeight = min(
+                Int(Foundation.floor(Double(originalHeight) / Double(originalWidth)))
+                    * sideMultiple,
+                maxSideLength
+            )
+        }
+
+        return CGSize(width: targetWidth, height: targetHeight)
+    }
+
+    func softTokenCount(for resizedSize: CGSize) -> Int {
+        let imageConfiguration = configuration.imageProcessor
+        let height = Int(resizedSize.height.rounded())
+        let width = Int(resizedSize.width.rounded())
+        let numPatches = (height / imageConfiguration.patchSize) * (width / imageConfiguration.patchSize)
+        return numPatches / (imageConfiguration.poolingKernelSize * imageConfiguration.poolingKernelSize)
+    }
+
+    func expandImagePlaceholders(in tokens: [Int], softTokenCounts: [Int]) throws -> [Int] {
+        guard !softTokenCounts.isEmpty else { return tokens }
+
+        var expanded = [Int]()
+        var softTokenIndex = 0
+
+        for token in tokens {
+            if token == specialTokens.imageTokenId {
+                guard softTokenIndex < softTokenCounts.count else {
+                    throw VLMError.processing("Missing Gemma 4 image token count for placeholder.")
+                }
+
+                expanded.append(specialTokens.boiTokenId)
+                expanded.append(
+                    contentsOf: Array(
+                        repeating: specialTokens.imageTokenId,
+                        count: softTokenCounts[softTokenIndex])
+                )
+                expanded.append(specialTokens.eoiTokenId)
+                softTokenIndex += 1
+            } else {
+                expanded.append(token)
+            }
+        }
+
+        guard softTokenIndex == softTokenCounts.count else {
+            throw VLMError.processing(
+                "Gemma 4 chat template did not emit enough image placeholders.")
+        }
+
+        return expanded
+    }
+
+    private func normalizePixels(_ pixels: MLXArray) -> MLXArray {
+        let meanValues = configuration.imageProcessor.imageMean.map { Float($0) }
+        let stdValues = configuration.imageProcessor.imageStd.map { Float($0) }
+        let mean = MLXArray(meanValues).reshaped(1, 3, 1, 1)
+        let std = MLXArray(stdValues).reshaped(1, 3, 1, 1)
+        return (pixels - mean) / std
+    }
+
+    func preprocess(image: CIImage, processing: UserInput.Processing?) throws -> PreparedImage {
+        var image = MediaProcessing.apply(image, processing: processing)
+
+        let targetSize = try resizedSize(for: image.extent.size)
+        image = MediaProcessing.resampleBicubic(image, to: targetSize)
+
+        // Gemma 4 parity depends on matching the Python processor's byte-oriented path:
+        // resize in image space, rasterize to 8-bit sRGB, apply 1/255 rescale when configured,
+        // then run optional normalization.
+        let sRGBColorSpace = CGColorSpace(name: CGColorSpace.sRGB)
+        var pixels = MediaProcessing.asMLXArray(
+            image,
+            colorSpace: sRGBColorSpace,
+            pixelScale: .byteFloat
+        )
+
+        if configuration.imageProcessor.doRescale {
+            pixels = pixels * configuration.imageProcessor.rescaleFactor
+        }
+
+        if configuration.imageProcessor.doNormalize {
+            pixels = normalizePixels(pixels)
+        }
+
+        let frame = THW(
+            1,
+            Int(targetSize.height.rounded()),
+            Int(targetSize.width.rounded())
+        )
+
+        return PreparedImage(
+            pixels: pixels,
+            frame: frame,
+            softTokenCount: softTokenCount(for: targetSize)
+        )
+    }
+
+    public func prepare(input: UserInput) async throws -> LMInput {
+        if !input.images.isEmpty, !input.videos.isEmpty {
+            throw VLMError.singleMediaTypeAllowed
+        }
+        if !input.videos.isEmpty {
+            throw VLMError.processing("Gemma4Processor supports text with an optional single image only.")
+        }
+        if input.images.count > 1 {
+            throw VLMError.singleImageAllowed
+        }
+
+        let messages = Gemma4MessageGenerator().generate(from: input)
+        let rawTemplateTokens = try tokenizer.applyChatTemplate(
+            messages: messages,
+            tools: input.tools,
+            additionalContext: chatTemplateContext(additionalContext: input.additionalContext)
+        )
+        let templateTokens = normalizeLeadingTemplateWhitespace(rawTemplateTokens)
+        #if DEBUG
+            debugParityTrace(
+                route: input.images.isEmpty ? .textOnly : .multimodal,
+                roles: messages.compactMap { $0["role"] as? String },
+                templateTokens: templateTokens
+            )
+        #endif
+
+        var promptTokens = templateTokens
+        var processedImage: LMInput.ProcessedImage?
+        if let firstImage = input.images.first {
+            let image = try preprocess(image: firstImage.asCIImage(), processing: input.processing)
+            promptTokens = try expandImagePlaceholders(
+                in: promptTokens, softTokenCounts: [image.softTokenCount])
+            #if DEBUG
+                debugParityTrace(
+                    route: .multimodal,
+                    roles: messages.compactMap { $0["role"] as? String },
+                    templateTokens: templateTokens,
+                    expandedTokens: promptTokens
+                )
+            #endif
+            processedImage = LMInput.ProcessedImage(
+                pixels: image.pixels,
+                frames: [image.frame]
+            )
+        }
+
+        let tokens = MLXArray(promptTokens).expandedDimensions(axis: 0)
+        let mask = ones(like: tokens).asType(.int8)
+
+        return LMInput(
+            text: .init(tokens: tokens, mask: mask),
+            image: processedImage
+        )
+    }
+}
