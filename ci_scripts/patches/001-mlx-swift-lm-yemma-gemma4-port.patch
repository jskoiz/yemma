+    func testQuantizedCompatibilityModeStillGeneratesWithPerLayerInputs() throws {
+        try requireMLXMetalLib()
+
+        let model = Gemma4TextModel(makeTinyConfig(quantization: .init(groupSize: 64, bits: 4)))
+        let inputIds = MLXArray([1, 2, 3])[.newAxis, .ellipsis]
