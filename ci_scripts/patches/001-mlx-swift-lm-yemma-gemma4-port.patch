+
+private struct DeterministicGemma4Tokenizer: Tokenizer {
+    private let tokens: [String: Int] = [
+        "<|image|>": 258880,
+        "<|image>": 255999,
+        "<image|>": 258882,
+        "<bos>": 2,
+        "<turn|>": 1,
+    ]
+
+    var bosToken: String? { "<bos>" }
+    var eosToken: String? { "<turn|>" }
+    var unknownToken: String? { "<unk>" }
+
+    func encode(text: String, addSpecialTokens: Bool) -> [Int] {
+        [42, 43]
+    }
+
+    func decode(tokenIds: [Int], skipSpecialTokens: Bool) -> String {
+        tokenIds.map(String.init).joined(separator: " ")
+    }
+
+    func convertTokenToId(_ token: String) -> Int? {
+        tokens[token]
+    }
+
+    func convertIdToToken(_ id: Int) -> String? {
+        tokens.first(where: { $0.value == id })?.key
+    }
+
+    func applyChatTemplate(
+        messages: [[String: any Sendable]],
+        tools: [[String: any Sendable]]?,
+        additionalContext: [String: any Sendable]?
+    ) throws -> [Int] {
+        let hasImage = messages.contains { message in
+            guard let content = message["content"] as? [MLXLMCommon.Message] else {
+                return false
+            }
+            return content.contains { ($0["type"] as? String) == "image" }
+        }
+        return hasImage ? [101, 258880, 102] : [101, 102]
+    }
+}
+
+private struct LeadingWhitespaceGemma4Tokenizer: Tokenizer {
+    var bosToken: String? { "<bos>" }
+    var eosToken: String? { "<turn|>" }
+    var unknownToken: String? { "<unk>" }
+
+    func encode(text: String, addSpecialTokens: Bool) -> [Int] {
+        []
+    }
+
+    func decode(tokenIds: [Int], skipSpecialTokens: Bool) -> String {
+        tokenIds.map { token in
+            switch token {
+            case 2: return "<bos>"
+            case 109: return "\n\n\n"
+            case 105: return "<|turn>user"
+            case 107: return "\n"
+            default: return "\(token)"
+            }
+        }.joined()
+    }
+
+    func convertTokenToId(_ token: String) -> Int? {
+        switch token {
+        case "<bos>": return 2
+        case "<turn|>": return 1
+        case "<unk>": return 3
+        default: return nil
+        }
+    }
+
+    func convertIdToToken(_ id: Int) -> String? {
+        switch id {
+        case 2: return "<bos>"
+        case 1: return "<turn|>"
+        case 3: return "<unk>"
+        default: return nil
+        }
+    }
+
+    func applyChatTemplate(
+        messages: [[String: any Sendable]],
+        tools: [[String: any Sendable]]?,
+        additionalContext: [String: any Sendable]?
+    ) throws -> [Int] {
+        [2, 109, 105, 107]
+    }
+}
