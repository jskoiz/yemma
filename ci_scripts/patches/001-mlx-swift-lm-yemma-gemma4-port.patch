+final class Gemma4Attention: Module {
+    let layerType: String
+    let isSliding: Bool
+    let headDim: Int
+    let numHeads: Int
+    let numKVHeads: Int
+    let useKEqualsV: Bool
+    let scale: Float = 1.0
+
+    @ModuleInfo(key: "q_proj") var qProj: Linear
+    @ModuleInfo(key: "k_proj") var kProj: Linear
+    @ModuleInfo(key: "v_proj") var vProj: Linear?
+    @ModuleInfo(key: "o_proj") var oProj: Linear
+    @ModuleInfo(key: "q_norm") var qNorm: RMSNorm
+    @ModuleInfo(key: "k_norm") var kNorm: RMSNorm
+    @ModuleInfo(key: "v_norm") var vNorm: Gemma4RMSNormNoScale
+    @ModuleInfo var rope: RoPELayer
+
+    init(_ config: Gemma4TextConfiguration, layerIdx: Int) {
+        self.layerType = config.layerTypes[layerIdx]
+        self.isSliding = layerType == "sliding_attention"
+        self.headDim =
+            if layerType == "full_attention", config.globalHeadDim > 0 {
+                config.globalHeadDim
+            } else {
+                config.headDim
+            }
+        self.numHeads = config.numAttentionHeads
+        self.useKEqualsV = config.attentionKEqualsV && !isSliding
+
+        if useKEqualsV, let numGlobalKeyValueHeads = config.numGlobalKeyValueHeads {
+            self.numKVHeads = numGlobalKeyValueHeads
+        } else {
+            self.numKVHeads = config.numKeyValueHeads
+        }
+
+        self._qProj.wrappedValue = Linear(
+            config.hiddenSize, config.numAttentionHeads * headDim, bias: false)
+        self._kProj.wrappedValue = Linear(
+            config.hiddenSize, numKVHeads * headDim, bias: false)
+        self._oProj.wrappedValue = Linear(
+            config.numAttentionHeads * headDim, config.hiddenSize, bias: false)
+
+        if useKEqualsV {
+            self._vProj.wrappedValue = nil
+        } else {
+            self._vProj.wrappedValue = Linear(
+                config.hiddenSize, numKVHeads * headDim, bias: false)
+        }
+
+        self._qNorm.wrappedValue = RMSNorm(dimensions: headDim, eps: config.rmsNormEps)
+        self._kNorm.wrappedValue = RMSNorm(dimensions: headDim, eps: config.rmsNormEps)
+        self._vNorm.wrappedValue = Gemma4RMSNormNoScale(eps: config.rmsNormEps)
+
+        let ropeKey = isSliding ? "sliding_attention" : "full_attention"
+        let ropeConfig = config.ropeParameters[ropeKey] ?? [:]
+        let ropeTheta = ropeConfig["rope_theta"]?.asFloat() ?? 10_000.0
+        let ropeType =
+            if case .string(let value) = ropeConfig["rope_type"] ?? .string("default") {
+                value
+            } else {
+                "default"
+            }
+
+        if ropeType == "proportional" {
+            let factor = ropeConfig["partial_rotary_factor"]?.asFloat() ?? config.globalPartialRotaryFactor
+            let rotatedDimensions = max(
+                2, Int((Float(headDim) * factor).rounded(.down)) / 2 * 2)
+            self._rope.wrappedValue = Gemma4ProportionalRoPE(
+                dimensions: headDim,
+                rotatedDimensions: rotatedDimensions,
+                traditional: config.ropeTraditional,
+                base: ropeTheta
+            )
+        } else {
+            self._rope.wrappedValue = initializeRope(
+                dims: headDim,
+                base: ropeTheta,
+                traditional: config.ropeTraditional,
+                scalingConfig: ropeConfig,
+                maxPositionEmbeddings: config.maxPositionEmbeddings
+            )
+        }
+
+        super.init()
+    }
+
+    private func debugShapeDescription(_ array: MLXArray) -> String {
+        "\(array.shape)"
+    }
+
+    private func preconditionProjectionReshapable(
+        _ projection: MLXArray,
+        batch: Int,
+        sequence: Int,
+        heads: Int,
+        headDim: Int,
+        context: String,
+        input: MLXArray,
+        cacheOffset: Int
+    ) {
+        let targetShape = [batch, sequence, heads, headDim]
+        let targetSize = targetShape.reduce(1, *)
+        precondition(
+            projection.size == targetSize,
+            """
+            Gemma4Attention \(context) reshape mismatch.
+            projectionShape=\(debugShapeDescription(projection))
+            projectionSize=\(projection.size)
+            targetShape=\(targetShape)
+            targetSize=\(targetSize)
+            inputShape=\(debugShapeDescription(input))
+            batch=\(batch)
+            sequence=\(sequence)
+            heads=\(heads)
+            headDim=\(headDim)
+            numKVHeads=\(numKVHeads)
+            cacheOffset=\(cacheOffset)
+            layerType=\(layerType)
+            """
+        )
+    }
+
+    func callAsFunction(
+        _ x: MLXArray,
+        mask: MLXFast.ScaledDotProductAttentionMaskMode? = nil,
+        cache: KVCache? = nil,
+        sharedKV: (MLXArray, MLXArray)? = nil,
+        offset: Int? = nil
+    ) -> (MLXArray, (MLXArray, MLXArray), Int) {
+        precondition(
+            x.ndim == 3,
+            "Gemma4Attention expected x as [B,S,H], got \(x.shape)"
+        )
+
+        let batch = x.dim(0)
+        let sequence = x.dim(1)
+        let cacheOffset = offset ?? cache?.offset ?? 0
+
+        let rawQueries = qProj(x)
+        preconditionProjectionReshapable(
+            rawQueries,
+            batch: batch,
+            sequence: sequence,
+            heads: numHeads,
+            headDim: headDim,
+            context: "q_proj",
+            input: x,
+            cacheOffset: cacheOffset
+        )
+        var queries = rawQueries.reshaped(batch, sequence, numHeads, headDim)
+        queries = qNorm(queries)
+        var keys: MLXArray
+        var values: MLXArray
+
+        if let sharedKV {
+            (keys, values) = sharedKV
+        } else {
+            let keyProjection = kProj(x)
+            preconditionProjectionReshapable(
+                keyProjection,
+                batch: batch,
+                sequence: sequence,
+                heads: numKVHeads,
+                headDim: headDim,
+                context: "k_proj",
+                input: x,
+                cacheOffset: cacheOffset
+            )
+            var rawKeys = keyProjection.reshaped(batch, sequence, numKVHeads, headDim)
+            var rawValues = rawKeys
+            if !useKEqualsV {
+                guard let vProj else {
+                    fatalError("Gemma4Attention is missing v_proj for non-k_eq_v configuration.")
+                }
+                let valueProjection = vProj(x)
+                preconditionProjectionReshapable(
+                    valueProjection,
+                    batch: batch,
+                    sequence: sequence,
+                    heads: numKVHeads,
+                    headDim: headDim,
+                    context: "v_proj",
+                    input: x,
+                    cacheOffset: cacheOffset
+                )
+                rawValues = valueProjection.reshaped(batch, sequence, numKVHeads, headDim)
+            }
+
+            rawKeys = kNorm(rawKeys)
+            rawValues = vNorm(rawValues)
+
+            keys = rawKeys.transposed(0, 2, 1, 3)
+            keys = rope(keys, offset: cacheOffset)
+
+            values = rawValues.transposed(0, 2, 1, 3)
+
+            if let cache {
+                precondition(
+                    !(cache is QuantizedKVCacheProtocol),
+                    "Gemma4Text shared-KV path does not support QuantizedKVCache."
+                )
+                (keys, values) = cache.update(keys: keys, values: values)
+            }
+        }
+
+        queries = queries.transposed(0, 2, 1, 3)
+        queries = rope(queries, offset: cacheOffset)
+
+        var adjustedMask = mask ?? .none
+        if case .array(let maskArray) = adjustedMask, maskArray.shape.last != keys.shape[keys.ndim - 2]
+        {
+            let keysLength = keys.shape[keys.ndim - 2]
+            adjustedMask = .array(maskArray[.ellipsis, (maskArray.shape.last! - keysLength)...])
+        }
+
+        let output = MLXFast.scaledDotProductAttention(
+            queries: queries,
+            keys: keys,
+            values: values,
+            scale: scale,
+            mask: adjustedMask
+        )
+        .transposed(0, 2, 1, 3)
+        .reshaped(batch, sequence, -1)
+
+        return (oProj(output), (keys, values), cacheOffset)
+    }
+}
+
+final class Gemma4DecoderLayer: Module {
+    let config: Gemma4TextConfiguration
+    let layerType: String
+
+    @ModuleInfo(key: "self_attn") var selfAttn: Gemma4Attention
+    @ModuleInfo var mlp: Gemma4MLP
+    @ModuleInfo(key: "input_layernorm") var inputLayerNorm: RMSNorm
+    @ModuleInfo(key: "post_attention_layernorm") var postAttentionLayerNorm: RMSNorm
+    @ModuleInfo(key: "pre_feedforward_layernorm") var preFeedforwardLayerNorm: RMSNorm
+    @ModuleInfo(key: "post_feedforward_layernorm") var postFeedforwardLayerNorm: RMSNorm
+
+    @ModuleInfo(key: "router") var router: Gemma4Router?
+    @ModuleInfo(key: "experts") var experts: Gemma4Experts?
+    @ModuleInfo(key: "post_feedforward_layernorm_1") var postFeedforwardLayerNorm1: RMSNorm?
+    @ModuleInfo(key: "post_feedforward_layernorm_2") var postFeedforwardLayerNorm2: RMSNorm?
+    @ModuleInfo(key: "pre_feedforward_layernorm_2") var preFeedforwardLayerNorm2: RMSNorm?
+
+    @ModuleInfo(key: "per_layer_input_gate") var perLayerInputGate: Linear?
+    @ModuleInfo(key: "per_layer_projection") var perLayerProjection: Linear?
+    @ModuleInfo(key: "post_per_layer_input_norm") var postPerLayerInputNorm: RMSNorm?
+    @ModuleInfo(key: "layer_scalar") var layerScalar: MLXArray
+
+    init(_ config: Gemma4TextConfiguration, layerIdx: Int) {
+        self.config = config
+        self.layerType = config.layerTypes[layerIdx]
+
+        self._selfAttn.wrappedValue = Gemma4Attention(config, layerIdx: layerIdx)
+        self._mlp.wrappedValue = Gemma4MLP(config, layerIdx: layerIdx)
+        self._inputLayerNorm.wrappedValue = RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._postAttentionLayerNorm.wrappedValue = RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._preFeedforwardLayerNorm.wrappedValue = RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._postFeedforwardLayerNorm.wrappedValue = RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+
+        if config.enableMoEBlock {
+            self._router.wrappedValue = Gemma4Router(config)
+            self._experts.wrappedValue = Gemma4Experts(config)
+            self._postFeedforwardLayerNorm1.wrappedValue = RMSNorm(
+                dimensions: config.hiddenSize, eps: config.rmsNormEps)
+            self._postFeedforwardLayerNorm2.wrappedValue = RMSNorm(
+                dimensions: config.hiddenSize, eps: config.rmsNormEps)
+            self._preFeedforwardLayerNorm2.wrappedValue = RMSNorm(
+                dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        } else {
+            self._router.wrappedValue = nil
+            self._experts.wrappedValue = nil
+            self._postFeedforwardLayerNorm1.wrappedValue = nil
+            self._postFeedforwardLayerNorm2.wrappedValue = nil
+            self._preFeedforwardLayerNorm2.wrappedValue = nil
+        }
+
+        if config.hiddenSizePerLayerInput > 0 {
+            self._perLayerInputGate.wrappedValue = Linear(
+                config.hiddenSize,
+                config.hiddenSizePerLayerInput,
+                bias: false
+            )
+            self._perLayerProjection.wrappedValue = Linear(
+                config.hiddenSizePerLayerInput,
+                config.hiddenSize,
+                bias: false
+            )
+            self._postPerLayerInputNorm.wrappedValue = RMSNorm(
+                dimensions: config.hiddenSize,
+                eps: config.rmsNormEps
+            )
+        } else {
+            self._perLayerInputGate.wrappedValue = nil
+            self._perLayerProjection.wrappedValue = nil
+            self._postPerLayerInputNorm.wrappedValue = nil
+        }
+
+        self._layerScalar.wrappedValue = MLXArray.ones([1])
+
+        super.init()
+    }
+
+    func callAsFunction(
+        _ x: MLXArray,
+        mask: MLXFast.ScaledDotProductAttentionMaskMode? = nil,
+        cache: KVCache? = nil,
+        perLayerInput: MLXArray? = nil,
+        sharedKV: (MLXArray, MLXArray)? = nil,
+        offset: Int? = nil
+    ) -> (MLXArray, (MLXArray, MLXArray), Int) {
+        let residual = x
+
+        var h = inputLayerNorm(x)
+        let (attentionOutput, nextSharedKV, nextOffset) = selfAttn(
+            h,
+            mask: mask,
+            cache: cache,
+            sharedKV: sharedKV,
+            offset: offset
+        )
+        h = postAttentionLayerNorm(attentionOutput)
+        h = residual + h
+
+        let feedForwardResidual = h
+
+        if
+            config.enableMoEBlock,
+            let router,
+            let experts,
+            let postFeedforwardLayerNorm1,
+            let postFeedforwardLayerNorm2,
+            let preFeedforwardLayerNorm2
+        {
+            let branch1 = postFeedforwardLayerNorm1(mlp(preFeedforwardLayerNorm(h)))
+            let (indices, weights) = router(h)
+            let branch2 = postFeedforwardLayerNorm2(
+                experts(preFeedforwardLayerNorm2(h), topKIndices: indices, topKWeights: weights))
+            h = branch1 + branch2
+        } else {
+            h = preFeedforwardLayerNorm(h)
+            h = mlp(h)
+        }
+
+        h = postFeedforwardLayerNorm(h)
+        h = feedForwardResidual + h
+
+        if
+            let perLayerInputGate,
+            let perLayerProjection,
+            let postPerLayerInputNorm,
+            let perLayerInput
+        {
+            let gateResidual = h
+            var gatedInput = geluApproximate(perLayerInputGate(h))
+            gatedInput = gatedInput * perLayerInput
+            gatedInput = perLayerProjection(gatedInput)
+            gatedInput = postPerLayerInputNorm(gatedInput)
+            h = gateResidual + gatedInput
+        }
+
+        h = h * layerScalar.asType(h.dtype)
+        return (h, nextSharedKV, nextOffset)
+    }
+}
+
+public final class Gemma4TextTransformer: Module {
+    let config: Gemma4TextConfiguration
+    let embedScale: Float
+    let embedTokensPerLayerScale: Float
+    let perLayerInputScale: MLXArray
+    let perLayerProjectionScale: MLXArray
+    let previousKVs: [Int]
+    let usesPerLayerInputs: Bool
+
+    @ModuleInfo(key: "embed_tokens") public var embedTokens: Embedding
+    @ModuleInfo(key: "layers") var layers: [Gemma4DecoderLayer]
+    @ModuleInfo(key: "norm") var norm: RMSNorm
+    @ModuleInfo(key: "embed_tokens_per_layer") var embedTokensPerLayer: Embedding?
+    @ModuleInfo(key: "per_layer_model_projection") var perLayerModelProjection: Linear?
+    @ModuleInfo(key: "per_layer_projection_norm") var perLayerProjectionNorm: RMSNorm?
+
+    public var firstKVSharedLayerIndex: Int {
+        max(config.numHiddenLayers - config.numKVSharedLayers, 0)
+    }
+
+    public init(_ config: Gemma4TextConfiguration) {
+        self.config = config
+        self.embedScale = pow(Float(config.hiddenSize), 0.5)
+        self.embedTokensPerLayerScale = pow(Float(max(config.hiddenSizePerLayerInput, 1)), 0.5)
+        self.perLayerInputScale = MLXArray(pow(2.0, -0.5))
+        self.perLayerProjectionScale = MLXArray(pow(Float(config.hiddenSize), -0.5))
+        self.usesPerLayerInputs = config.hiddenSizePerLayerInput > 0
+
+        self._embedTokens.wrappedValue = Embedding(
+            embeddingCount: config.vocabSize,
+            dimensions: config.hiddenSize
+        )
+        self._layers.wrappedValue = (0 ..< config.numHiddenLayers).map {
+            Gemma4DecoderLayer(config, layerIdx: $0)
+        }
+        self._norm.wrappedValue = RMSNorm(
+            dimensions: config.hiddenSize,
+            eps: config.rmsNormEps
+        )
+
+        if config.hiddenSizePerLayerInput > 0 {
+            self._embedTokensPerLayer.wrappedValue = Embedding(
+                embeddingCount: config.vocabSizePerLayerInput,
+                dimensions: config.numHiddenLayers * config.hiddenSizePerLayerInput
+            )
+            self._perLayerModelProjection.wrappedValue = Linear(
+                config.hiddenSize,
+                config.numHiddenLayers * config.hiddenSizePerLayerInput,
+                bias: false
+            )
+            self._perLayerProjectionNorm.wrappedValue = RMSNorm(
+                dimensions: config.hiddenSizePerLayerInput,
+                eps: config.rmsNormEps
+            )
+        } else {
+            self._embedTokensPerLayer.wrappedValue = nil
+            self._perLayerModelProjection.wrappedValue = nil
+            self._perLayerProjectionNorm.wrappedValue = nil
+        }
+
+        var previousKVs = Array(0 ..< config.numHiddenLayers)
+        if config.numKVSharedLayers > 0 {
+            let splitIndex = max(config.numHiddenLayers - config.numKVSharedLayers, 0)
+            var kvsByType: [String: Int] = [:]
+            for index in 0 ..< splitIndex {
+                kvsByType[config.layerTypes[index]] = index
+            }
+            for index in splitIndex ..< config.numHiddenLayers {
+                if let previousIndex = kvsByType[config.layerTypes[index]] {
+                    previousKVs[index] = previousIndex
+                }
+            }
+        }
+        self.previousKVs = previousKVs
+
+        super.init()
+
+    }
+
+    private static func requiresQuantizedPerLayerCompatibilityFallback(
+        _ config: Gemma4TextConfiguration
+    ) -> Bool {
+        config.usesQuantizedPerLayerCompatibilityFallback
+    }
+
+    override public func updateMissing(
+        parameter: String,
+        verify: VerifyUpdate,
+        path: [String],
+        modulePath: [String]
+    ) throws {
+        if parameter == "perLayerInputScale" || parameter == "perLayerProjectionScale" {
+            return
+        }
+
+        try super.updateMissing(
+            parameter: parameter,
+            verify: verify,
+            path: path,
+            modulePath: modulePath
+        )
+    }
+
+    private func denseEmbeddingWeight() -> MLXArray {
+        if let quantized = embedTokens as? QuantizedEmbedding {
+            return dequantized(
+                quantized.weight,
+                scales: quantized.scales,
+                biases: quantized.biases,
+                groupSize: quantized.groupSize,
+                bits: quantized.bits,
+                mode: quantized.mode
+            )
+        }
+        return embedTokens.weight
+    }
+
+    private func hasUsableEmbedding(
+        _ embedding: Embedding?,
+        expectedDimensions: Int
+    ) -> Bool {
+        guard let embedding else {
+            return false
+        }
+
+        if let quantized = embedding as? QuantizedEmbedding {
+            return quantized.weight.size > 0
+                && quantized.scales.size > 0
+                && quantized.shape.1 == expectedDimensions
+        }
+
+        return embedding.weight.size > 0 && embedding.shape.1 == expectedDimensions
+    }
+
+    private func hasUsableLinear(
+        _ linear: Linear?,
+        expectedOutputDimensions: Int
+    ) -> Bool {
+        guard let linear else {
+            return false
+        }
+
+        if let quantized = linear as? QuantizedLinear {
+            return quantized.weight.size > 0
+                && quantized.scales.size > 0
+                && quantized.shape.0 == expectedOutputDimensions
+        }
+
+        return linear.weight.size > 0 && linear.shape.0 == expectedOutputDimensions
+    }
+
+    private func expectedPerLayerInputShape(prefixShape: [Int]) -> [Int] {
+        prefixShape + [config.numHiddenLayers, config.hiddenSizePerLayerInput]
+    }
+
+    private func debugShapeDescription(_ array: MLXArray?) -> String {
+        guard let array else {
+            return "nil"
+        }
+        return "\(array.shape)"
+    }
+
+    private func preconditionExpectedFeatureCount(
+        _ array: MLXArray,
+        expectedFeatureCount: Int,
+        context: String
+    ) {
+        precondition(
+            array.ndim > 0 && array.dim(-1) == expectedFeatureCount,
+            """
+            Gemma4 \(context) feature mismatch.
+            shape=\(array.shape)
+            size=\(array.size)
+            expectedTrailing=\(expectedFeatureCount)
+            quantization=\(String(describing: config.quantization))
+            usesPerLayerInputs=\(usesPerLayerInputs)
+            hiddenSizePerLayerInput=\(config.hiddenSizePerLayerInput)
+            numHiddenLayers=\(config.numHiddenLayers)
+            """
+        )
+    }
+
+    private func preconditionReshapable(
+        _ array: MLXArray,
+        targetShape: [Int],
+        context: String,
+        inputEmbeddings: MLXArray? = nil,
+        perLayerInputs: MLXArray? = nil
+    ) {
+        let targetSize = targetShape.reduce(1, *)
+        precondition(
+            array.size == targetSize,
+            """
+            Gemma4 \(context) reshape mismatch.
+            currentShape=\(array.shape)
+            currentSize=\(array.size)
+            targetShape=\(targetShape)
+            targetSize=\(targetSize)
+            inputEmbeddingsShape=\(debugShapeDescription(inputEmbeddings))
+            perLayerInputsShape=\(debugShapeDescription(perLayerInputs))
+            quantization=\(String(describing: config.quantization))
+            usesPerLayerInputs=\(usesPerLayerInputs)
+            hiddenSizePerLayerInput=\(config.hiddenSizePerLayerInput)
+            numHiddenLayers=\(config.numHiddenLayers)
+            """
+        )
+    }
+
+    private func emptyPerLayerInputs(prefixShape: [Int], dtype: DType = .float32) -> MLXArray {
+        MLXArray.zeros(expectedPerLayerInputShape(prefixShape: prefixShape), dtype: dtype)
+    }
+
+    func getPerLayerInputs(
+        inputIds: MLXArray?,
+        inputEmbeddings: MLXArray? = nil
+    ) -> MLXArray {
+        let expectedFeatureCount = config.numHiddenLayers * config.hiddenSizePerLayerInput
+        guard
+            hasUsableEmbedding(
+                embedTokensPerLayer,
+                expectedDimensions: expectedFeatureCount
+            )
+        else {
+            if let inputIds {
+                return emptyPerLayerInputs(prefixShape: Array(inputIds.shape))
+            }
+            if let inputEmbeddings {
+                return emptyPerLayerInputs(
+                    prefixShape: Array(inputEmbeddings.shape.dropLast()),
+                    dtype: inputEmbeddings.dtype
+                )
+            }
+            fatalError("Gemma4TextTransformer requires inputIds or inputEmbeddings.")
+        }
+        guard let embedTokensPerLayer else {
+            fatalError("Gemma4TextTransformer has no per-layer embedding table.")
+        }
+
+        let resolvedInputIds: MLXArray
+        if let inputIds {
+            resolvedInputIds = inputIds
+        } else {
+            guard let inputEmbeddings else {
+                fatalError("inputEmbeddings must be provided when inputIds are omitted.")
+            }
+
+            let embeddingWeight = denseEmbeddingWeight()
+            let embeddingNorms = embeddingWeight.square().sum(axis: -1)
+            let inputNorms = inputEmbeddings.square().sum(axis: -1)
+            let dotProducts = matmul(inputEmbeddings, embeddingWeight.T)
+            let distances = gemma4CompleteSquare(
+                embeddingNorms: embeddingNorms,
+                inputNorms: inputNorms,
+                dotProducts: dotProducts
+            )
+            resolvedInputIds = argMin(distances, axis: -1)
+        }
+
+        var result = embedTokensPerLayer(resolvedInputIds)
+        guard result.size > 0, result.ndim > 0, result.dim(-1) == expectedFeatureCount else {
+            return emptyPerLayerInputs(prefixShape: Array(resolvedInputIds.shape), dtype: result.dtype)
+        }
+        result = result * MLXArray(embedTokensPerLayerScale, dtype: result.dtype)
+        let targetShape = expectedPerLayerInputShape(prefixShape: Array(resolvedInputIds.shape))
+        preconditionExpectedFeatureCount(
+            result,
+            expectedFeatureCount: expectedFeatureCount,
+            context: "getPerLayerInputs"
+        )
+        preconditionReshapable(
+            result,
+            targetShape: targetShape,
+            context: "getPerLayerInputs",
+            perLayerInputs: nil
+        )
+        return result.reshaped(targetShape)
+    }
+
+    func projectPerLayerInputs(
+        _ inputEmbeddings: MLXArray,
+        perLayerInputs: MLXArray?
+    ) -> MLXArray {
+        let expectedFeatureCount = config.numHiddenLayers * config.hiddenSizePerLayerInput
+        guard
+            hasUsableLinear(
+                perLayerModelProjection,
+                expectedOutputDimensions: expectedFeatureCount
+            ),
+            let perLayerModelProjection,
+            let perLayerProjectionNorm
+        else {
+            guard let perLayerInputs else {
+                return emptyPerLayerInputs(
+                    prefixShape: Array(inputEmbeddings.shape.dropLast()),
+                    dtype: inputEmbeddings.dtype
+                )
+            }
+            return perLayerInputs
+        }
+
+        var projected = perLayerModelProjection(inputEmbeddings)
+        guard
+            projected.size > 0,
+            projected.ndim > 0,
+            projected.dim(-1) == expectedFeatureCount
+        else {
+            guard let perLayerInputs else {
+                return emptyPerLayerInputs(
+                    prefixShape: Array(inputEmbeddings.shape.dropLast()),
+                    dtype: inputEmbeddings.dtype
+                )
+            }
+            return perLayerInputs
+        }
+        projected = projected * perLayerProjectionScale.asType(projected.dtype)
+        let targetShape = expectedPerLayerInputShape(prefixShape: Array(inputEmbeddings.shape.dropLast()))
+        preconditionExpectedFeatureCount(
+            projected,
+            expectedFeatureCount: expectedFeatureCount,
+            context: "projectPerLayerInputs"
+        )
+        preconditionReshapable(
+            projected,
+            targetShape: targetShape,
+            context: "projectPerLayerInputs",
+            inputEmbeddings: inputEmbeddings,
+            perLayerInputs: perLayerInputs
+        )
+        projected = projected.reshaped(targetShape)
+        projected = perLayerProjectionNorm(projected)
+
+        guard let perLayerInputs else {
+            return projected
+        }
+
+        guard projected.shape == perLayerInputs.shape else {
+            return projected
+        }
+
+        return (projected + perLayerInputs) * perLayerInputScale.asType(projected.dtype)
+    }
+
+    private func projectPerLayerInputsIfPossible(
+        _ inputEmbeddings: MLXArray,
+        perLayerInputs: MLXArray?
+    ) -> MLXArray? {
+        let expectedFeatureCount = config.numHiddenLayers * config.hiddenSizePerLayerInput
+        guard
+            hasUsableLinear(
+                perLayerModelProjection,
+                expectedOutputDimensions: expectedFeatureCount
+            ),
+            let perLayerModelProjection,
+            let perLayerProjectionNorm
+        else {
+            return perLayerInputs
+        }
+
+        var projected = perLayerModelProjection(inputEmbeddings)
+        guard
+            projected.size > 0,
+            projected.ndim > 0,
+            projected.dim(-1) == expectedFeatureCount
+        else {
+            return perLayerInputs
+        }
+
+        projected = projected * perLayerProjectionScale.asType(projected.dtype)
+        let prefixShape = Array(inputEmbeddings.shape.dropLast())
+        let targetShape = expectedPerLayerInputShape(prefixShape: prefixShape)
+        let targetSize = targetShape.reduce(1, *)
+        guard projected.size == targetSize else {
+            return perLayerInputs
+        }
+
+        projected = projected.reshaped(targetShape)
+        projected = perLayerProjectionNorm(projected)
+
+        guard let perLayerInputs else {
+            return projected
+        }
+
+        guard projected.shape == perLayerInputs.shape else {
+            return projected
+        }
+
+        return (projected + perLayerInputs) * perLayerInputScale.asType(projected.dtype)
+    }
+
+    private func makeMasks(
+        hiddenStates: MLXArray,
+        cache: [KVCache?]
+    ) -> [MLXFast.ScaledDotProductAttentionMaskMode] {
+        var fullAttentionMask: MLXFast.ScaledDotProductAttentionMaskMode?
+        var slidingAttentionMask: MLXFast.ScaledDotProductAttentionMaskMode?
+        var masks: [MLXFast.ScaledDotProductAttentionMaskMode] = []
+        masks.reserveCapacity(layers.count)
+
+        for (layer, layerCache) in zip(layers, cache) {
+            if layer.layerType == "full_attention" {
+                if fullAttentionMask == nil {
+                    fullAttentionMask = createAttentionMask(h: hiddenStates, cache: layerCache)
+                }
+                masks.append(fullAttentionMask!)
+            } else {
+                if slidingAttentionMask == nil {
+                    slidingAttentionMask = createAttentionMask(
+                        h: hiddenStates,
+                        cache: layerCache,
+                        windowSize: config.slidingWindow
+                    )
+                }
+                masks.append(slidingAttentionMask!)
+            }
+        }
+
+        return masks
+    }
+
+    private func alignPerLayerInputs(
+        _ perLayerInputs: MLXArray?,
+        to inputEmbeddings: MLXArray,
+        cache: [KVCache?]
+    ) -> MLXArray? {
+        guard let perLayerInputs else {
+            return nil
+        }
+
+        let targetLength = inputEmbeddings.dim(1)
+        guard perLayerInputs.ndim >= 2, perLayerInputs.dim(1) != targetLength else {
+            return perLayerInputs
+        }
+
+        let cacheOffset = cache.compactMap { $0?.offset }.first ?? 0
+        let maxStart = max(perLayerInputs.dim(1) - targetLength, 0)
+        let start = min(cacheOffset, maxStart)
+        let end = start + targetLength
+        return perLayerInputs[0..., start ..< end, 0..., 0...]
+    }
+
+    func callAsFunction(
+        inputs: MLXArray? = nil,
+        cache: [KVCache]? = nil,
+        inputEmbeddings: MLXArray? = nil,
+        perLayerInputs: MLXArray? = nil,
+        mask: MLXFast.ScaledDotProductAttentionMaskMode? = nil
+    ) -> MLXArray {
+        let embeddings: MLXArray
+        let shouldApplyEmbedScale: Bool
+        if let inputEmbeddings {
+            embeddings = inputEmbeddings
+            shouldApplyEmbedScale = false
+        } else if let inputs {
+            embeddings = embedTokens(inputs)
+            shouldApplyEmbedScale = true
+        } else {
+            fatalError("Either inputs or inputEmbeddings must be provided.")
+        }
+
+        precondition(
+            embeddings.ndim == 3,
+            "Gemma4TextTransformer expected rank-3 embeddings [B,S,H], got \(embeddings.shape)"
+        )
+
+        var hiddenStates =
+            shouldApplyEmbedScale
+            ? embeddings * MLXArray(embedScale, dtype: embeddings.dtype)
+            : embeddings
+
+        var expandedCache = cache?.map { $0 as KVCache? } ?? []
+        if expandedCache.count < config.numHiddenLayers {
+            expandedCache.append(
+                contentsOf: Array(repeating: nil as KVCache?, count: config.numHiddenLayers - expandedCache.count)
+            )
+        }
+
+        let resolvedPerLayerInputs: [MLXArray?]
+        if usesPerLayerInputs && config.hiddenSizePerLayerInput > 0 {
+            let shouldBypassProjectedPerLayerInputs =
+                Self.requiresQuantizedPerLayerCompatibilityFallback(config)
+            let rawPerLayerInputs =
+                if let inputs, perLayerInputs == nil {
+                    getPerLayerInputs(inputIds: inputs, inputEmbeddings: nil)
+                } else if let inputEmbeddings {
+                    alignPerLayerInputs(
+                        perLayerInputs,
+                        to: inputEmbeddings,
+                        cache: expandedCache
+                    )
+                } else {
+                    perLayerInputs
+                }
+
+            if let rawPerLayerInputs {
+                let projectedPerLayerInputs =
+                    if shouldBypassProjectedPerLayerInputs {
+                        projectPerLayerInputsIfPossible(
+                            embeddings,
+                            perLayerInputs: rawPerLayerInputs
+                        ) ?? rawPerLayerInputs
+                    } else {
+                        projectPerLayerInputs(
+                            embeddings,
+                            perLayerInputs: rawPerLayerInputs
+                        )
+                    }
+                precondition(
+                    projectedPerLayerInputs.ndim == 4
+                        && projectedPerLayerInputs.dim(-2) == config.numHiddenLayers
+                        && projectedPerLayerInputs.dim(-1) == config.hiddenSizePerLayerInput,
+                    """
+                    Gemma4 resolved per-layer inputs have unexpected shape.
+                    shape=\(projectedPerLayerInputs.shape)
+                    rawShape=\(debugShapeDescription(rawPerLayerInputs))
+                    embeddingsShape=\(embeddings.shape)
+                    quantization=\(String(describing: config.quantization))
+                    usesPerLayerInputs=\(usesPerLayerInputs)
+                    """
+                )
+                resolvedPerLayerInputs = (0 ..< config.numHiddenLayers).map { layerIndex in
+                    projectedPerLayerInputs[0..., 0..., layerIndex, 0...]
+                }
+            } else {
+                resolvedPerLayerInputs = Array(repeating: nil, count: config.numHiddenLayers)
+            }
+        } else {
+            resolvedPerLayerInputs = Array(repeating: nil, count: config.numHiddenLayers)
+        }
+
+        let masks =
+            if let mask {
+                Array(repeating: mask, count: config.numHiddenLayers)
+            } else {
+                makeMasks(hiddenStates: hiddenStates, cache: expandedCache)
+            }
+
+        var intermediates = Array(repeating: Optional<((MLXArray, MLXArray), Int)>.none, count: config.numHiddenLayers)
+
+        for layerIndex in 0 ..< config.numHiddenLayers {
+            let previousIndex = previousKVs[layerIndex]
+            let previousState = intermediates[previousIndex]
+            let (nextHiddenStates, sharedKV, offset) = layers[layerIndex](
+                hiddenStates,
+                mask: masks[layerIndex],
+                cache: expandedCache[layerIndex],
+                perLayerInput: resolvedPerLayerInputs[layerIndex],
+                sharedKV: previousState?.0,
+                offset: previousState?.1
+            )
+            hiddenStates = nextHiddenStates
+            intermediates[layerIndex] = (sharedKV, offset)
+        }
+
+        return norm(hiddenStates)
+    }
+}
+
+public final class Gemma4TextModel: Module, Gemma4TextBackbone {
+    @ModuleInfo(key: "model") public var model: Gemma4TextTransformer
+    @ModuleInfo(key: "lm_head") var lmHead: Module?
+
+    public let config: Gemma4TextConfiguration
+
+    public var hiddenSize: Int {
+        config.hiddenSize
+    }
+
+    public var layers: [Module] {
+        model.layers
+    }
+
+    public var kvHeads: [Int] {
+        config.layerTypes.map { layerType in
+            if layerType == "full_attention" {
+                return config.numGlobalKeyValueHeads ?? config.numKeyValueHeads
+            }
+            return config.numKeyValueHeads
+        }
+    }
+
+    public var headDim: Int {
+        config.headDim
+    }
+
+    public var nKVHeads: Int {
+        config.numKeyValueHeads
+    }
+
+    public var quantPredicate: (String, Module) -> (groupSize: Int, bits: Int, mode: QuantizationMode)?
+    {
+        { path, module in
+            guard module is Quantizable else {
+                return nil
+            }
+            if path.contains("router.proj")
+                || path.hasSuffix("mlp.gate_proj")
+                || path.hasSuffix("mlp.up_proj")
+                || path.hasSuffix("mlp.down_proj")
+            {
+                return (64, 8, .affine)
+            }
+            return (64, 4, .affine)
+        }
+    }
+
+    public init(_ config: Gemma4TextConfiguration) {
+        self.config = config
+        self._model.wrappedValue = Gemma4TextTransformer(config)
+
+        if config.tieWordEmbeddings {
+            self._lmHead.wrappedValue = nil
+        } else {
+            self._lmHead.wrappedValue = Linear(config.hiddenSize, config.vocabSize, bias: false)
+        }
+
+        super.init()
+    }
+
+    public func newCache(parameters: GenerateParameters?) -> [KVCache] {
+        let firstKVSharedLayerIndex = model.firstKVSharedLayerIndex
+        let slidingWindow = parameters?.maxKVSize ?? config.slidingWindow
+
+        var caches: [KVCache] = []
+        caches.reserveCapacity(firstKVSharedLayerIndex)
+        for layerIndex in 0 ..< firstKVSharedLayerIndex {
+            let layerType = config.layerTypes[layerIndex]
+            if layerType == "full_attention" {
+                caches.append(StandardKVCache())
+            } else {
+                caches.append(RotatingKVCache(maxSize: slidingWindow, keep: 0))
+            }
+        }
+        return caches
+    }
+
+    public func prepare(
+        _ input: LMInput,
+        cache: [KVCache],
+        windowSize: Int? = nil
+    ) throws -> PrepareResult {
+        .tokens(input.text)
+    }
+
+    public func callAsFunction(_ inputs: MLXArray, cache: [KVCache]? = nil) -> MLXArray {
+        precondition(
+            inputs.ndim == 2,
+            "Gemma4TextModel expected rank-2 token inputs [batch, seq], got \(inputs.shape)"
+        )
+        return callAsFunction(inputs: inputs, cache: cache, inputEmbeddings: nil, perLayerInputs: nil)
+    }
+
+    public func embedTokens(_ inputIds: MLXArray) -> MLXArray {
+        model.embedTokens(inputIds)
+    }
+
+    public func perLayerInputs(_ inputIds: MLXArray) -> MLXArray? {
+        model.usesPerLayerInputs && config.hiddenSizePerLayerInput > 0
+            ? model.getPerLayerInputs(inputIds: inputIds)
+            : nil
+    }
+
+    public func callAsFunction(
+        inputs: MLXArray? = nil,
+        cache: [KVCache]? = nil,
+        inputEmbeddings: MLXArray? = nil,
+        perLayerInputs: MLXArray? = nil,
+        mask: MLXFast.ScaledDotProductAttentionMaskMode? = nil
+    ) -> MLXArray {
+        if let inputs {
+            precondition(
+                inputs.ndim == 2,
+                "Gemma4TextModel expected rank-2 token inputs [batch, seq], got \(inputs.shape)"
+            )
+        }
+
+        if let inputEmbeddings {
+            precondition(
+                inputEmbeddings.ndim == 3,
+                """
+                Gemma4TextModel expected rank-3 embeddings [batch, seq, hidden].
+                Got shape=\(inputEmbeddings.shape)
+                """
+            )
+        }
+
+        var output = model(
+            inputs: inputs,
+            cache: cache,
+            inputEmbeddings: inputEmbeddings,
+            perLayerInputs: perLayerInputs,
+            mask: mask
+        )
+
+        if let linear = lmHead as? Linear {
+            output = linear(output)
+        } else if let quantized = lmHead as? QuantizedLinear {
+            output = quantized(output)
+        } else {
+            output = model.embedTokens.asLinear(output)
+        }
+
+        if let softcap = config.finalLogitSoftcapping {
+            output = gemma4LogitSoftcap(softcap, output)
+        }
+
+        return output
+    }
+
+    public func callAsFunction(
+        inputIds: MLXArray?,
+        cache: [KVCache]?,
+        inputsEmbeds: MLXArray,
+        perLayerInputs: MLXArray?
+    ) -> LMOutput {
+        LMOutput(
+            logits: callAsFunction(
+                inputs: inputIds,
+                cache: cache,
+                inputEmbeddings: inputsEmbeds,
+                perLayerInputs: perLayerInputs
+            )
+        )
+    }
+
+    private func hasQuantizedWeights(layerPath: String, in weights: [String: MLXArray]) -> Bool {
+        let scalesKey = "\(layerPath).scales"
+        let biasesKey = "\(layerPath).biases"
+        let weightKey = "\(layerPath).weight"
+        return weights[scalesKey] != nil
+            && weights[biasesKey] != nil
+            && weights[weightKey]?.dtype == .uint32
+    }
+
+    private func normalizeWeightKey(_ key: String) -> String? {
+        let droppedPrefixes = [
+            "vision_tower.", "audio_tower.", "multi_modal_projector.", "audio_projector.",
+            "vision_model.", "audio_model.", "image_projector.", "mm_input_projection.",
+            "model.vision_tower.", "model.audio_tower.", "model.multi_modal_projector.",
+        ]
+        if droppedPrefixes.contains(where: { key.hasPrefix($0) }) {
+            return nil
+        }
+
+        var normalizedKey = key
+
+        for prefix in ["model.language_model.", "language_model."] where normalizedKey.hasPrefix(prefix) {
+            normalizedKey.removeFirst(prefix.count)
+        }
+
+        while normalizedKey.contains("model.model.") {
+            normalizedKey = normalizedKey.replacingOccurrences(of: "model.model.", with: "model.")
+        }
+
+        return normalizedKey
+    }
+
+    public func sanitize(
+        weights: [String: MLXArray],
+        quantization: BaseConfiguration.Quantization?
+    ) -> [String: MLXArray] {
+        var sanitized: [String: MLXArray] = [:]
+
+        for (key, value) in weights {
+            if key.contains("self_attn.rotary_emb") {
+                continue
+            }
+            if key.contains("input_max")
+                || key.contains("input_min")
+                || key.contains("output_max")
+                || key.contains("output_min")
+            {
+                continue
+            }
+
+            guard let normalizedKey = normalizeWeightKey(key) else {
+                continue
+            }
+
+            if normalizedKey.hasSuffix(".experts.gate_up_proj") {
+                let base = String(normalizedKey.dropLast(".gate_up_proj".count))
+                let parts = value.split(parts: 2, axis: -2)
+                sanitized["\(base).switch_glu.gate_proj.weight"] = parts[0].contiguous()
+                sanitized["\(base).switch_glu.up_proj.weight"] = parts[1].contiguous()
+                continue
+            }
+
+            if normalizedKey.hasSuffix(".experts.down_proj") {
+                let base = String(normalizedKey.dropLast(".down_proj".count))
+                sanitized["\(base).switch_glu.down_proj.weight"] = value
+                continue
+            }
+
+            sanitized[normalizedKey] = value
+        }
+
+        let keysToTrim = [
+            ("model.embed_tokens", config.vocabSize),
+            ("model.embed_tokens_per_layer", config.vocabSizePerLayerInput),
+            ("lm_head", config.vocabSize),
+        ]
+        for (prefix, expectedSize) in keysToTrim {
+            for suffix in ["weight", "scales", "biases"] {
+                let key = "\(prefix).\(suffix)"
+                if let tensor = sanitized[key], tensor.ndim > 0, tensor.dim(0) > expectedSize {
+                    sanitized[key] = tensor[0 ..< expectedSize]
+                }
+            }
+        }
+
+        let hasQuantizedParameters = sanitized.contains { key, value in
+            key.hasSuffix(".weight") && value.dtype == .uint32
+        }
+
+        if hasQuantizedParameters {
+            let defaultQuantization =
+                quantization?.asTuple
+                ?? config.quantization?.asTuple
+                ?? (64, 4, QuantizationMode.affine)
+            quantize(model: self) { [quantPredicate] path, module in
+                guard hasQuantizedWeights(layerPath: path, in: sanitized) else {
+                    return nil
+                }
+                if let inferredQuantization = inferQuantization(
+                    layerPath: path,
+                    module: module,
+                    weights: sanitized,
+                    defaultQuantization: defaultQuantization
+                ) {
+                    return inferredQuantization
+                }
+                return quantPredicate(path, module) ?? defaultQuantization
+            }
+        }
+
+        return sanitized
+    }
+
+    public func sanitize(weights: [String: MLXArray]) -> [String: MLXArray] {
+        sanitize(weights: weights, quantization: nil)
+    }
+
+    private func inferQuantization(
+        layerPath: String,
+        module: Module,
+        weights: [String: MLXArray],
+        defaultQuantization: (groupSize: Int, bits: Int, mode: QuantizationMode)
+    ) -> (groupSize: Int, bits: Int, mode: QuantizationMode)? {
+        guard let quantizedWeight = weights["\(layerPath).weight"], quantizedWeight.ndim >= 2 else {
+            return nil
+        }
+        let packedInputWidth = quantizedWeight.dim(-1)
+
+        let inputWidth: Int
+        if let linear = module as? Linear {
+            inputWidth = linear.weight.dim(-1)
+        } else if let quantizedLinear = module as? QuantizedLinear {
+            inputWidth = quantizedLinear.weight.dim(-1) * defaultQuantization.bits / 32
+        } else {
+            return nil
+        }
+
+        guard inputWidth > 0, packedInputWidth > 0 else {
+            return nil
+        }
+
+        let inferredBits = packedInputWidth * 32 / inputWidth
+        guard [2, 4, 8].contains(inferredBits) else {
+            return nil
+        }
+
+        return (defaultQuantization.groupSize, inferredBits, defaultQuantization.mode)
+    }
+}
+
+extension Gemma4TextModel: LoRAModel {
+    public var loraLayers: [Module] {
+        model.layers
+    }
+}
