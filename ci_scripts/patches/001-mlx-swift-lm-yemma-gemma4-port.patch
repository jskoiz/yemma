+final class Gemma4RMSNormNoScale: Module {
+    let eps: Float
+
+    init(eps: Float = 1.0e-6) {
+        self.eps = eps
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray) -> MLXArray {
+        MLXFast.rmsNorm(x, weight: MLXArray.mlxNone, eps: eps)
+    }
+}
+
+private func gemma4LogitSoftcap(_ softcap: Float, _ x: MLXArray) -> MLXArray {
+    let scale = MLXArray(softcap, dtype: x.dtype)
+    return tanh(x / scale) * scale
+}
+
+private func gemma4CompleteSquare(
+    embeddingNorms: MLXArray,
+    inputNorms: MLXArray,
+    dotProducts: MLXArray
+) -> MLXArray {
+    embeddingNorms + expandedDimensions(inputNorms, axis: -1) - (2 * dotProducts)
+}
+
+final class Gemma4MLP: Module {
+    @ModuleInfo(key: "gate_proj") var gateProj: Linear
+    @ModuleInfo(key: "down_proj") var downProj: Linear
+    @ModuleInfo(key: "up_proj") var upProj: Linear
+
+    init(_ config: Gemma4TextConfiguration, layerIdx: Int) {
+        let firstKVSharedLayerIdx = config.numHiddenLayers - config.numKVSharedLayers
+        let isKVSharedLayer = layerIdx >= firstKVSharedLayerIdx && firstKVSharedLayerIdx > 0
+        let useDoubleWide = config.useDoubleWideMLP && isKVSharedLayer
+        let hiddenDimensions = config.intermediateSize * (useDoubleWide ? 2 : 1)
+
+        self._gateProj.wrappedValue = Linear(config.hiddenSize, hiddenDimensions, bias: false)
+        self._downProj.wrappedValue = Linear(hiddenDimensions, config.hiddenSize, bias: false)
+        self._upProj.wrappedValue = Linear(config.hiddenSize, hiddenDimensions, bias: false)
+
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray) -> MLXArray {
+        downProj(geluApproximate(gateProj(x)) * upProj(x))
+    }
+}
+
+final class Gemma4Router: Module {
+    let config: Gemma4TextConfiguration
+    let rootSize: Float
+
+    @ModuleInfo(key: "proj") var proj: Linear
+    @ModuleInfo(key: "scale") var scale: MLXArray
+    @ModuleInfo(key: "per_expert_scale") var perExpertScale: MLXArray
+
+    init(_ config: Gemma4TextConfiguration) {
+        self.config = config
+        self.rootSize = pow(Float(config.hiddenSize), -0.5)
+
+        self._proj.wrappedValue = Linear(
+            config.hiddenSize,
+            config.numExperts ?? 1,
+            bias: false
+        )
+        self._scale.wrappedValue = MLXArray.ones([config.hiddenSize])
+        self._perExpertScale.wrappedValue = MLXArray.ones([config.numExperts ?? 1])
+
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray) -> (MLXArray, MLXArray) {
+        let scaledWeight = scale * rootSize
+        let normalized = MLXFast.rmsNorm(x, weight: scaledWeight, eps: config.rmsNormEps)
+        let expertScores = proj(normalized)
+
+        let topK = config.topKExperts ?? 1
+        let indices = MLX.argPartition(-expertScores, kth: topK - 1, axis: -1)[.ellipsis, ..<topK]
+        var weights = MLX.takeAlong(expertScores, indices, axis: -1)
+        weights = softmax(weights, axis: -1, precise: true)
+        weights = weights * perExpertScale[indices]
+
+        return (indices, weights)
+    }
+}
+
+final class Gemma4Experts: Module {
+    @ModuleInfo(key: "switch_glu") var switchGLU: SwitchGLU
+
+    init(_ config: Gemma4TextConfiguration) {
+        self._switchGLU.wrappedValue = SwitchGLU(
+            inputDims: config.hiddenSize,
+            hiddenDims: config.moeIntermediateSize ?? config.intermediateSize,
+            numExperts: config.numExperts ?? 1,
+            activation: geluApproximate,
+            bias: false
+        )
+
+        super.init()
+    }
+
+    func callAsFunction(
+        _ x: MLXArray,
+        topKIndices: MLXArray,
+        topKWeights: MLXArray
+    ) -> MLXArray {
+        let batch = x.dim(0)
+        let sequence = x.dim(1)
+        let hidden = x.dim(2)
+        let experts = topKIndices.dim(-1)
+
+        let xFlat = x.reshaped(batch * sequence, hidden)
+        let indicesFlat = topKIndices.reshaped(batch * sequence, experts)
+        let expertOutput = switchGLU(xFlat, indicesFlat)
+
+        let weights = expandedDimensions(topKWeights.reshaped(batch * sequence, experts), axis: -1)
+        let mixed = (weights * expertOutput).sum(axis: -2)
+        return mixed.reshaped(batch, sequence, hidden)
+    }
+}
