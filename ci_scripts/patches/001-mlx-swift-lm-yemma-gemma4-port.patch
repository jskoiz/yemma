+
+    private func assertUpdateAllowsMissingDerivedKey(
+        _ shouldKeepParameter: (String) -> Bool,
+        file: StaticString = #filePath,
+        line: UInt = #line
+    ) throws {
+        try requireMLXMetalLib()
+
+        let model = Gemma4TextModel(makeTinyConfig())
+        let filteredParameters = model.parameters().flattened().filter { key, _ in shouldKeepParameter(key) }
+        let parameters = ModuleParameters.unflattened(filteredParameters)
+
+        XCTAssertNoThrow(
+            try model.update(parameters: parameters, verify: [.allModelKeysSet]),
+            file: file,
+            line: line
+        )
+    }
