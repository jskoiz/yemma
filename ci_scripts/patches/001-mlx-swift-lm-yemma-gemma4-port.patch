@@ -0,0 +1,290 @@
+import MLX
+import MLXLMCommon
+import MLXNN
+import XCTest
+@testable import MLXVLM
+
+final class Gemma4VLMTests: XCTestCase {
+
+    final class StubGemma4TextBackbone: Module, Gemma4TextBackbone {
+        @ModuleInfo(key: "embed_tokens") var embedLayer: Embedding
+
+        let hiddenSize: Int
+        let kvHeads: [Int]
+
+        var lastInputsEmbeds: MLXArray?
+        var lastPerLayerInputs: MLXArray?
+
+        init(vocabularySize: Int = 512, hiddenSize: Int = 8, hiddenLayers: Int = 2) {
+            self.hiddenSize = hiddenSize
+            self.kvHeads = Array(repeating: 1, count: hiddenLayers)
+            self._embedLayer.wrappedValue = Embedding(
+                embeddingCount: vocabularySize, dimensions: hiddenSize)
+            super.init()
+        }
+
+        var loraLayers: [Module] { [embedLayer] }
+
+        func embedTokens(_ inputIds: MLXArray) -> MLXArray {
+            embedLayer(inputIds)
+        }
+
+        func perLayerInputs(_ inputIds: MLXArray) -> MLXArray? {
+            inputIds.asType(.float32)[0..., 0..., .newAxis]
+        }
+
+        func callAsFunction(
+            inputIds: MLXArray?, cache: [KVCache]?, inputsEmbeds: MLXArray, perLayerInputs: MLXArray?
+        ) -> LMOutput {
+            lastInputsEmbeds = inputsEmbeds
+            lastPerLayerInputs = perLayerInputs
+            return LMOutput(logits: inputsEmbeds)
+        }
+
+        func prepare(_ input: LMInput, cache: [KVCache], windowSize: Int?) throws -> PrepareResult {
+            .logits(LMOutput(logits: embedTokens(input.text.tokens)))
+        }
+
+        func callAsFunction(_ inputs: MLXArray, cache: [KVCache]?) -> MLXArray {
+            embedTokens(inputs)
+        }
+
+        func sanitize(
+            weights: [String: MLXArray], quantization: BaseConfiguration.Quantization?
+        ) -> [String: MLXArray] {
+            weights
+        }
+    }
+
+    private func makeConfiguration(
+        defaultOutputLength: Int = 2, poolingKernelSize: Int = 1
+    ) throws -> Gemma4Configuration {
+        let json = """
+        {
+          "model_type": "gemma4",
+          "vocab_size": 256,
+          "image_token_id": 99,
+          "audio_token_id": 100,
+          "boi_token_id": 101,
+          "eoi_token_id": 102,
+          "hidden_size": 8,
+          "pad_token_id": 0,
+          "vision_soft_tokens_per_image": \(defaultOutputLength),
+          "quantization": {
+            "group_size": 64,
+            "bits": 4
+          },
+          "text_config": {
+            "model_type": "gemma4_text",
+            "hidden_size": 8,
+            "num_hidden_layers": 2,
+            "vocab_size": 256,
+            "num_key_value_heads": 1,
+            "hidden_size_per_layer_input": 4
+          },
+          "vision_config": {
+            "model_type": "gemma4_vision",
+            "hidden_size": 8,
+            "intermediate_size": 16,
+            "num_hidden_layers": 1,
+            "num_attention_heads": 1,
+            "num_key_value_heads": 1,
+            "head_dim": 8,
+            "rms_norm_eps": 0.000001,
+            "max_position_embeddings": 256,
+            "default_output_length": \(defaultOutputLength),
+            "patch_size": 16,
+            "position_embedding_size": 32,
+            "pooling_kernel_size": \(poolingKernelSize),
+            "rope_parameters": {
+              "rope_theta": 100.0,
+              "rope_type": "default"
+            },
+            "use_clipped_linears": false,
+            "standardize": false
+          }
+        }
+        """
+
+        return try JSONDecoder().decode(Gemma4Configuration.self, from: Data(json.utf8))
+    }
+
+    private func makeModel() throws -> (Gemma4<StubGemma4TextBackbone>, StubGemma4TextBackbone) {
+        let configuration = try makeConfiguration()
+        let textBackbone = StubGemma4TextBackbone(
+            vocabularySize: configuration.vocabularySize,
+            hiddenSize: configuration.textConfiguration.hiddenSize,
+            hiddenLayers: configuration.textConfiguration.numHiddenLayers
+        )
+        return (Gemma4(configuration, languageModel: textBackbone), textBackbone)
+    }
+
+    func testConfigurationDecodesVisionAndTopLevelFields() throws {
+        let configuration = try makeConfiguration(defaultOutputLength: 280, poolingKernelSize: 3)
+
+        XCTAssertEqual(configuration.modelType, "gemma4")
+        XCTAssertEqual(configuration.imageTokenId, 99)
+        XCTAssertEqual(configuration.visionSoftTokensPerImage, 280)
+        XCTAssertEqual(configuration.quantization, BaseConfiguration.Quantization(groupSize: 64, bits: 4))
+        XCTAssertEqual(
+            configuration.textConfiguration.quantization,
+            BaseConfiguration.Quantization(groupSize: 64, bits: 4)
+        )
+        XCTAssertTrue(configuration.textConfiguration.usesQuantizedPerLayerCompatibilityFallback)
+        XCTAssertEqual(configuration.textConfiguration.hiddenSizePerLayerInput, 4)
+        XCTAssertEqual(configuration.visionConfiguration.modelType, "gemma4_vision")
+        XCTAssertEqual(configuration.visionConfiguration.defaultOutputLength, 280)
+        XCTAssertEqual(configuration.visionConfiguration.poolingKernelSize, 3)
+        XCTAssertEqual(configuration.visionConfiguration.ropeTheta, 100.0, accuracy: 1e-6)
+    }
+
+    func testMaskedScatterReplacesOnlyMaskedSlots() throws {
+        try requireMLXMetalLib()
+
+        let inputTensor = MLXArray([10.0 as Float, 11.0, 20.0, 21.0, 30.0, 31.0]).reshaped([1, 3, 2])
+        let source = MLXArray([100.0 as Float, 101.0, 200.0, 201.0]).reshaped([1, 2, 2])
+        let specialMask = MLXArray([0 as Int32, 1, 1]).reshaped([1, 3]).asType(.bool)
+        let maskExpanded = broadcast(
+            specialMask.expandedDimensions(axis: -1), to: inputTensor.shape)
+
+        let scattered = try maskedScatter(inputTensor: inputTensor, mask: maskExpanded, source: source)
+        let values = scattered.asArray(Float.self)
+
+        XCTAssertEqual(values, [10.0, 11.0, 100.0, 101.0, 200.0, 201.0])
+    }
+
+    func testPrepareWithSingleImageBuildsMultimodalEmbeddings() throws {
+        try requireMLXMetalLib()
+
+        let (model, textBackbone) = try makeModel()
+        let tokens = MLXArray([1 as Int32, 101, 99, 99, 102, 2]).reshaped([1, 6])
+        let pixels = MLXArray.ones([1, 3, 16, 32], dtype: .float32)
+        let input = LMInput(
+            text: .init(tokens: tokens),
+            image: .init(pixels: pixels)
+        )
+
+        let expected = try model.getInputEmbeddings(inputIds: tokens, pixelValues: pixels)
+        let result = try model.prepare(input, cache: model.newCache(parameters: nil), windowSize: nil)
+
+        guard case .logits(let output) = result else {
+            return XCTFail("Expected logits from multimodal prepare")
+        }
+
+        XCTAssertEqual(output.logits.shape, [1, 6, 8])
+        XCTAssertNotNil(textBackbone.lastInputsEmbeds)
+        XCTAssertNotNil(textBackbone.lastPerLayerInputs)
+        XCTAssertEqual(textBackbone.lastInputsEmbeds?.ndim, 3)
+        XCTAssertEqual(textBackbone.lastInputsEmbeds?.shape, [1, 6, 8])
+        XCTAssertEqual(textBackbone.lastPerLayerInputs?.ndim, 3)
+        XCTAssertEqual(textBackbone.lastPerLayerInputs?.shape, [1, 6, 1])
+        XCTAssertEqual(
+            textBackbone.lastInputsEmbeds?.asArray(Float.self),
+            expected.inputsEmbeds.asArray(Float.self)
+        )
+
+        let perLayer = try XCTUnwrap(textBackbone.lastPerLayerInputs)
+        let perLayerValues = perLayer.squeezed(axis: -1).asArray(Float.self)
+        XCTAssertEqual(perLayerValues, [1.0, 101.0, 0.0, 0.0, 102.0, 2.0])
+    }
+
+    func testPrepareWithoutImageFallsBackToTextBackbone() throws {
+        try requireMLXMetalLib()
+
+        let (model, textBackbone) = try makeModel()
+        let tokens = MLXArray([1 as Int32, 2, 3]).reshaped([1, 3])
+        let input = LMInput(text: .init(tokens: tokens))
+
+        let result = try model.prepare(input, cache: model.newCache(parameters: nil), windowSize: nil)
+
+        guard case .logits(let output) = result else {
+            return XCTFail("Expected logits from text-only prepare")
+        }
+
+        XCTAssertEqual(output.logits.shape, [1, 3, 8])
+        XCTAssertEqual(output.logits.ndim, 3)
+        XCTAssertNil(textBackbone.lastInputsEmbeds)
+        XCTAssertNil(textBackbone.lastPerLayerInputs)
+    }
+
+    func testSanitizeDropsAudioKeysAndRemapsLanguageModelPrefix() throws {
+        try requireMLXMetalLib()
+
+        let (model, _) = try makeModel()
+        let weights: [String: MLXArray] = [
+            "model.audio_tower.foo.weight": MLXArray([1 as Float]),
+            "model.embed_audio.embedding_projection.weight": MLXArray([2 as Float]),
+            "model.language_model.layers.0.test.weight": MLXArray([3 as Float]),
+            "model.vision_tower.encoder.layers.0.self_attn.q_proj.input_min": MLXArray([4 as Float]),
+            "model.vision_tower.patch_embedder.input_proj.weight": MLXArray([5 as Float]),
+        ]
+
+        let sanitized = model.sanitize(weights: weights)
+
+        XCTAssertNil(sanitized["audio_tower.foo.weight"])
+        XCTAssertNil(sanitized["embed_audio.embedding_projection.weight"])
+        XCTAssertNil(sanitized["vision_tower.encoder.layers.0.self_attn.q_proj.input_min"])
+        XCTAssertNotNil(sanitized["language_model.model.layers.0.test.weight"])
+        XCTAssertNotNil(sanitized["vision_tower.patch_embedder.input_proj.weight"])
+    }
+
+    func testSanitizeQuantizesMultimodalProjectionWhenCheckpointCarriesQuantizedWeights() throws {
+        try requireMLXMetalLib()
+
+        let (model, _) = try makeModel()
+        let weights: [String: MLXArray] = [
+            "model.embed_vision.embedding_projection.weight": MLXArray.zeros([8, 1], dtype: .uint32),
+            "model.embed_vision.embedding_projection.scales": MLXArray.zeros([8, 1], dtype: .float32),
+            "model.embed_vision.embedding_projection.biases": MLXArray.zeros([8, 1], dtype: .float32),
+        ]
+
+        let sanitized = model.sanitize(weights: weights)
+        XCTAssertNotNil(sanitized["embed_vision.embedding_projection.weight"])
+        XCTAssertNotNil(sanitized["embed_vision.embedding_projection.scales"])
+        XCTAssertNotNil(sanitized["embed_vision.embedding_projection.biases"])
+
+        let projector = model.leafModules().flattened().first { path, _ in
+            path.hasSuffix("embed_vision.embedding_projection")
+                || path.hasSuffix("embedVision.embeddingProjection")
+        }?.1
+
+        XCTAssertTrue(projector is QuantizedLinear)
+    }
+
+    func testMaskedScatterThrowsOnFeatureTokenMismatch() throws {
+        try requireMLXMetalLib()
+
+        let inputTensor = MLXArray([10.0 as Float, 11.0, 20.0, 21.0, 30.0, 31.0]).reshaped([1, 3, 2])
+        let source = MLXArray([100.0 as Float, 101.0]).reshaped([1, 1, 2])
+        let specialMask = MLXArray([0 as Int32, 1, 1]).reshaped([1, 3]).asType(.bool)
+        let maskExpanded = broadcast(
+            specialMask.expandedDimensions(axis: -1), to: inputTensor.shape)
+
+        XCTAssertThrowsError(
+            try maskedScatter(inputTensor: inputTensor, mask: maskExpanded, source: source)
+        ) { error in
+            XCTAssertEqual(
+                error as? Gemma4VLMError,
+                .featureTokenMismatch(expected: 2, actual: 1)
+            )
+        }
+    }
+
+    func testPrepareRejectsUnsupportedImageRank() throws {
+        try requireMLXMetalLib()
+
+        let (model, _) = try makeModel()
+        let tokens = MLXArray([1 as Int32, 99, 2]).reshaped([1, 3])
+        let pixels = MLXArray.ones([16, 32], dtype: .float32)
+        let input = LMInput(
+            text: .init(tokens: tokens),
+            image: .init(pixels: pixels)
+        )
+
+        XCTAssertThrowsError(
+            try model.prepare(input, cache: model.newCache(parameters: nil), windowSize: nil)
+        ) { error in
+            XCTAssertEqual(error as? Gemma4VLMError, .unsupportedImageRank(2))
+        }
+    }
+}
