diff --git a/Tests/MLXLMTests/Gemma4TestSupport.swift b/Tests/MLXLMTests/Gemma4TestSupport.swift
new file mode 100644
index 0000000..cda69a6
--- /dev/null
+++ b/Tests/MLXLMTests/Gemma4TestSupport.swift
@@ -0,0 +1,94 @@
+import Foundation
+import XCTest
+
+private enum Gemma4MetalLibTestEnvironment {
+    static let lock = NSLock()
+    nonisolated(unsafe) static var workingDirectory: URL?
+}
+
+func requireMLXMetalLib(
+    filePath: StaticString = #filePath
+) throws {
+    let workingDirectory = try prepareMetalLibWorkingDirectory(filePath: filePath)
+    guard FileManager.default.changeCurrentDirectoryPath(workingDirectory.path) else {
+        throw XCTSkip("Unable to switch to temporary working directory for MLX metallib fallback.")
+    }
+}
+
+private func prepareMetalLibWorkingDirectory(filePath: StaticString) throws -> URL {
+    Gemma4MetalLibTestEnvironment.lock.lock()
+    defer { Gemma4MetalLibTestEnvironment.lock.unlock() }
+
+    if let workingDirectory = Gemma4MetalLibTestEnvironment.workingDirectory {
+        return workingDirectory
+    }
+
+    let fileManager = FileManager.default
+    let source = try macOSMetalLibURL(filePath: filePath)
+    let workingDirectory = fileManager.temporaryDirectory
+        .appending(path: "mlx-swift-lm-gemma4-metallib-\(ProcessInfo.processInfo.processIdentifier)")
+
+    if fileManager.fileExists(atPath: workingDirectory.path) {
+        try fileManager.removeItem(at: workingDirectory)
+    }
+    try fileManager.createDirectory(at: workingDirectory, withIntermediateDirectories: true)
+    try fileManager.copyItem(at: source, to: workingDirectory.appending(path: "default.metallib"))
+
+    Gemma4MetalLibTestEnvironment.workingDirectory = workingDirectory
+    return workingDirectory
+}
+
+private func macOSMetalLibURL(filePath: StaticString) throws -> URL {
+    let testsDirectory = URL(fileURLWithPath: "\(filePath)").deletingLastPathComponent()
+    let repositoryRoot = testsDirectory.deletingLastPathComponent().deletingLastPathComponent()
+    let derivedDataRoot = URL(fileURLWithPath: NSHomeDirectory(), isDirectory: true)
+        .appendingPathComponent("Library/Developer/Xcode/DerivedData")
+
+    let searchRoots = [
+        repositoryRoot.appendingPathComponent(".build"),
+        derivedDataRoot,
+    ]
+
+    for searchRoot in searchRoots {
+        if let candidate = firstMacOSMetalLib(in: searchRoot) {
+            return candidate
+        }
+    }
+
+    throw XCTSkip("MLX default metallib is unavailable in this test environment.")
+}
+
+private func firstMacOSMetalLib(in root: URL) -> URL? {
+    guard FileManager.default.fileExists(atPath: root.path) else {
+        return nil
+    }
+
+    guard let enumerator = FileManager.default.enumerator(
+        at: root,
+        includingPropertiesForKeys: nil
+    ) else {
+        return nil
+    }
+
+    let candidates = enumerator.compactMap { element -> URL? in
+        guard let url = element as? URL, url.lastPathComponent == "default.metallib" else {
+            return nil
+        }
+
+        let lowercasedPath = url.path.lowercased()
+        guard !lowercasedPath.contains("iphoneos"), !lowercasedPath.contains("iphonesimulator") else {
+            return nil
+        }
+
+        return url
+    }
+
+    return candidates.sorted { lhs, rhs in
+        let lhsScore = lhs.path.lowercased().contains("macos") ? 0 : 1
+        let rhsScore = rhs.path.lowercased().contains("macos") ? 0 : 1
+        if lhsScore == rhsScore {
+            return lhs.path < rhs.path
+        }
+        return lhsScore < rhsScore
+    }.first
+}
