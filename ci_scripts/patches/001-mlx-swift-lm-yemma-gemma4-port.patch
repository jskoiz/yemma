+// MARK: - Vision
+
+final class Gemma4VisionAttention: Module {
+    let numAttentionHeads: Int
+    let numKeyValueHeads: Int
+    let headDim: Int
+    let hiddenSize: Int
+    let ropeBaseFrequency: Float
+    let scale: Float
+
+    @ModuleInfo(key: "q_proj") var qProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "k_proj") var kProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "v_proj") var vProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "o_proj") var oProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "q_norm") var qNorm: Gemma4VisionRMSNorm
+    @ModuleInfo(key: "k_norm") var kNorm: Gemma4VisionRMSNorm
+
+    let vNorm: Gemma4VisionRMSNormNoScale
+
+    init(config: Gemma4VisionConfiguration) {
+        self.numAttentionHeads = config.attentionHeads
+        self.numKeyValueHeads = config.keyValueHeads
+        self.headDim = config.headDim
+        self.hiddenSize = config.hiddenSize
+        self.ropeBaseFrequency = config.ropeTheta
+        self.scale = 1.0
+
+        self._qProj.wrappedValue = Gemma4ClippableLinear(
+            hiddenSize, numAttentionHeads * headDim, useClipping: config.useClippedLinears)
+        self._kProj.wrappedValue = Gemma4ClippableLinear(
+            hiddenSize, numKeyValueHeads * headDim, useClipping: config.useClippedLinears)
+        self._vProj.wrappedValue = Gemma4ClippableLinear(
+            hiddenSize, numKeyValueHeads * headDim, useClipping: config.useClippedLinears)
+        self._oProj.wrappedValue = Gemma4ClippableLinear(
+            numAttentionHeads * headDim, hiddenSize, useClipping: config.useClippedLinears)
+        self._qNorm.wrappedValue = Gemma4VisionRMSNorm(dimensions: headDim, eps: config.rmsNormEps)
+        self._kNorm.wrappedValue = Gemma4VisionRMSNorm(dimensions: headDim, eps: config.rmsNormEps)
+        self.vNorm = Gemma4VisionRMSNormNoScale(eps: config.rmsNormEps)
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray, positions: MLXArray, mask: MLXArray? = nil) -> MLXArray {
+        let batch = x.dim(0)
+        let length = x.dim(1)
+
+        var queries = qProj(x).reshaped(batch, length, numAttentionHeads, headDim)
+        var keys = kProj(x).reshaped(batch, length, numKeyValueHeads, headDim)
+        var values = vProj(x).reshaped(batch, length, numKeyValueHeads, headDim)
+
+        queries = qNorm(queries)
+        keys = kNorm(keys)
+        values = vNorm(values)
+
+        queries = applyGemma4MultidimensionalRoPE(
+            queries, positions: positions, baseFrequency: ropeBaseFrequency)
+        keys = applyGemma4MultidimensionalRoPE(
+            keys, positions: positions, baseFrequency: ropeBaseFrequency)
+
+        queries = queries.transposed(0, 2, 1, 3)
+        keys = keys.transposed(0, 2, 1, 3)
+        values = values.transposed(0, 2, 1, 3)
+
+        let output = MLXFast.scaledDotProductAttention(
+            queries: queries, keys: keys, values: values, scale: scale,
+            mask: mask.map { .array($0) } ?? .none
+        )
+        .transposed(0, 2, 1, 3)
+        .reshaped(batch, length, -1)
+
+        return oProj(output)
+    }
+}
+
+final class Gemma4VisionMLP: Module {
+    @ModuleInfo(key: "gate_proj") var gateProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "up_proj") var upProj: Gemma4ClippableLinear
+    @ModuleInfo(key: "down_proj") var downProj: Gemma4ClippableLinear
+
+    init(config: Gemma4VisionConfiguration) {
+        self._gateProj.wrappedValue = Gemma4ClippableLinear(
+            config.hiddenSize, config.intermediateSize, useClipping: config.useClippedLinears)
+        self._upProj.wrappedValue = Gemma4ClippableLinear(
+            config.hiddenSize, config.intermediateSize, useClipping: config.useClippedLinears)
+        self._downProj.wrappedValue = Gemma4ClippableLinear(
+            config.intermediateSize, config.hiddenSize, useClipping: config.useClippedLinears)
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray) -> MLXArray {
+        downProj(geluApproximate(gateProj(x)) * upProj(x))
+    }
+}
+
+final class Gemma4VisionTransformerBlock: Module {
+    @ModuleInfo(key: "self_attn") var selfAttention: Gemma4VisionAttention
+    @ModuleInfo var mlp: Gemma4VisionMLP
+    @ModuleInfo(key: "input_layernorm") var inputLayerNorm: Gemma4RMSNorm
+    @ModuleInfo(key: "post_attention_layernorm") var postAttentionLayerNorm: Gemma4RMSNorm
+    @ModuleInfo(key: "pre_feedforward_layernorm") var preFeedforwardLayerNorm: Gemma4RMSNorm
+    @ModuleInfo(key: "post_feedforward_layernorm") var postFeedforwardLayerNorm: Gemma4RMSNorm
+
+    init(config: Gemma4VisionConfiguration) {
+        self._selfAttention.wrappedValue = Gemma4VisionAttention(config: config)
+        self._mlp.wrappedValue = Gemma4VisionMLP(config: config)
+        self._inputLayerNorm.wrappedValue = Gemma4RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._postAttentionLayerNorm.wrappedValue = Gemma4RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._preFeedforwardLayerNorm.wrappedValue = Gemma4RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        self._postFeedforwardLayerNorm.wrappedValue = Gemma4RMSNorm(
+            dimensions: config.hiddenSize, eps: config.rmsNormEps)
+        super.init()
+    }
+
+    func callAsFunction(_ x: MLXArray, positions: MLXArray, mask: MLXArray? = nil) -> MLXArray {
+        let attnOut = postAttentionLayerNorm(selfAttention(inputLayerNorm(x), positions: positions, mask: mask))
+        let hidden = x + attnOut
+        let ffwOut = postFeedforwardLayerNorm(mlp(preFeedforwardLayerNorm(hidden)))
+        return hidden + ffwOut
+    }
+}
+
+final class Gemma4VisionPatchEmbedder: Module {
+    let hiddenSize: Int
+    let patchSize: Int
+    let positionEmbeddingSize: Int
+
+    @ModuleInfo(key: "input_proj") var inputProj: Linear
+    @ParameterInfo(key: "position_embedding_table") var positionEmbeddingTable: MLXArray
+
+    init(config: Gemma4VisionConfiguration) {
+        self.hiddenSize = config.hiddenSize
+        self.patchSize = config.patchSize
+        self.positionEmbeddingSize = config.positionEmbeddingSize
+        self._inputProj.wrappedValue = Linear(3 * patchSize * patchSize, hiddenSize, bias: false)
+        self._positionEmbeddingTable.wrappedValue = MLXArray.ones([
+            2, positionEmbeddingSize, hiddenSize,
+        ])
+        super.init()
+    }
+
+    private func positionEmbeddings(
+        patchPositions: MLXArray, paddingPositions: MLXArray
+    ) -> MLXArray {
+        let hot = gemma4OneHot(patchPositions, numClasses: positionEmbeddingSize).transposed(0, 2, 1, 3)
+            .asType(positionEmbeddingTable.dtype)
+        var embeddings = einsum("bdlp,dph->blh", hot, positionEmbeddingTable)
+        let paddingMask = expandedDimensions(paddingPositions, axis: -1)
+        embeddings = MLX.where(
+            paddingMask, MLXArray.zeros(like: embeddings), embeddings)
+        return embeddings
+    }
+
+    private func patchify(_ pixelValues: MLXArray) -> MLXArray {
+        let batch = pixelValues.dim(0)
+        let channels = pixelValues.dim(1)
+        let height = pixelValues.dim(2)
+        let width = pixelValues.dim(3)
+        let patchesH = height / patchSize
+        let patchesW = width / patchSize
+
+        var patches = pixelValues.reshaped(batch, channels, patchesH, patchSize, patchesW, patchSize)
+        patches = patches.transposed(0, 2, 4, 3, 5, 1)
+        patches = patches.reshaped(batch, patchesH * patchesW, channels * patchSize * patchSize)
+        patches = 2.0 * (patches - 0.5)
+        return inputProj(patches.asType(inputProj.weight.dtype))
+    }
+
+    func callAsFunction(
+        _ pixelValues: MLXArray, patchPositions: MLXArray, paddingPositions: MLXArray
+    ) -> MLXArray {
+        patchify(pixelValues) + positionEmbeddings(
+            patchPositions: patchPositions, paddingPositions: paddingPositions)
+    }
+}
+
+final class Gemma4VisionPooler: Module {
+    let hiddenSize: Int
+    let defaultOutputLength: Int
+    let rootHiddenSize: Float
+
+    init(config: Gemma4VisionConfiguration) {
+        self.hiddenSize = config.hiddenSize
+        self.defaultOutputLength = config.defaultOutputLength
+        self.rootHiddenSize = pow(Float(config.hiddenSize), 0.5)
+        super.init()
+    }
+
+    private func avgPoolByPositions(
+        _ x: MLXArray, patchPositions: MLXArray, length: Int
+    ) -> (MLXArray, MLXArray) {
+        let inputLength = x.dim(1)
+        let kernel = Int(sqrt(Double(max(1, inputLength / max(1, length)))))
+        let kernelSquared = max(1, kernel * kernel)
+
+        let clamped = maximum(patchPositions.asType(.int32), MLXArray(0, dtype: .int32))
+        let maxX = clamped[0..., 0..., 0].max(axis: -1, keepDims: true) + 1
+        let kernelIndices2D = floor(clamped.asType(.float32) / Float(kernel)).asType(.int32)
+        let pooledWidth = floor(maxX.asType(.float32) / Float(kernel)).asType(.int32)
+        let kernelIndices = kernelIndices2D[0..., 0..., 0] + pooledWidth * kernelIndices2D[0..., 0..., 1]
+
+        let weights = gemma4OneHot(kernelIndices, numClasses: length).asType(.float32) / Float(kernelSquared)
+        let output = einsum("bln,bld->bnd", weights, x).asType(x.dtype)
+        let validMask = weights.sum(axis: 1) .> MLXArray(0.0, dtype: .float32)
+        return (output, validMask)
+    }
+
+    func callAsFunction(
+        _ hiddenStates: MLXArray, patchPositions: MLXArray, paddingPositions: MLXArray,
+        outputLength: Int? = nil
+    ) -> (MLXArray, MLXArray) {
+        let maskedStates = MLX.where(
+            expandedDimensions(paddingPositions, axis: -1),
+            MLXArray.zeros(like: hiddenStates),
+            hiddenStates
+        )
+
+        let length = outputLength ?? defaultOutputLength
+        if hiddenStates.dim(1) == length {
+            return (maskedStates * rootHiddenSize, paddingPositions .== MLXArray(false))
+        }
+
+        let (pooled, validMask) = avgPoolByPositions(maskedStates, patchPositions: patchPositions, length: length)
+        return (pooled * rootHiddenSize, validMask)
+    }
+}
+
+final class Gemma4VisionTransformerModel: Module {
+    @ModuleInfo var layers: [Gemma4VisionTransformerBlock]
+
+    init(config: Gemma4VisionConfiguration) {
+        self._layers.wrappedValue = (0 ..< config.hiddenLayers).map { _ in
+            Gemma4VisionTransformerBlock(config: config)
+        }
+        super.init()
+    }
+
+    func callAsFunction(_ hiddenStates: MLXArray, positions: MLXArray, mask: MLXArray) -> MLXArray {
+        var hiddenStates = hiddenStates
+        for layer in layers {
+            hiddenStates = layer(hiddenStates, positions: positions, mask: mask)
+        }
+        return hiddenStates
+    }
+}
+
+final class Gemma4VisionModel: Module {
+    let config: Gemma4VisionConfiguration
+    let patchSize: Int
+    let poolingKernelSize: Int
+    let defaultOutputLength: Int
+    let maxPatches: Int
+
+    @ModuleInfo(key: "patch_embedder") var patchEmbedder: Gemma4VisionPatchEmbedder
+    @ModuleInfo(key: "encoder") var encoder: Gemma4VisionTransformerModel
+    @ModuleInfo(key: "pooler") var pooler: Gemma4VisionPooler
+    @ParameterInfo(key: "std_bias") var stdBias: MLXArray
+    @ParameterInfo(key: "std_scale") var stdScale: MLXArray
+
+    init(config: Gemma4VisionConfiguration) {
+        self.config = config
+        self.patchSize = config.patchSize
+        self.poolingKernelSize = config.poolingKernelSize
+        self.defaultOutputLength = config.defaultOutputLength
+        self.maxPatches = config.defaultOutputLength * config.poolingKernelSize * config.poolingKernelSize
+        self._patchEmbedder.wrappedValue = Gemma4VisionPatchEmbedder(config: config)
+        self._encoder.wrappedValue = Gemma4VisionTransformerModel(config: config)
+        self._pooler.wrappedValue = Gemma4VisionPooler(config: config)
+        self._stdBias.wrappedValue = MLXArray.zeros([config.hiddenSize])
+        self._stdScale.wrappedValue = MLXArray.ones([config.hiddenSize])
+        super.init()
+    }
+
+    private func patchPositionsSingle(height: Int, width: Int) -> (MLXArray, MLXArray, Int) {
+        let patchesH = height / patchSize
+        let patchesW = width / patchSize
+        let numPatches = min(maxPatches, patchesH * patchesW)
+
+        var positionStorage = Array(repeating: Int32(-1), count: maxPatches * 2)
+        var paddingStorage = Array(repeating: true, count: maxPatches)
+
+        var index = 0
+        for y in 0 ..< patchesH {
+            for x in 0 ..< patchesW {
+                guard index < maxPatches else { break }
+                positionStorage[index * 2] = Int32(x)
+                positionStorage[index * 2 + 1] = Int32(y)
+                paddingStorage[index] = false
+                index += 1
+            }
+        }
+
+        let positions = MLXArray(positionStorage).reshaped([maxPatches, 2])
+        let padding = MLXArray(paddingStorage)
+        return (positions, padding, numPatches)
+    }
+
+    func callAsFunction(_ pixelValues: MLXArray) -> MLXArray {
+        let inputs =
+            if pixelValues.ndim == 3 {
+                pixelValues.expandedDimensions(axis: 0)
+            } else if pixelValues.ndim == 4 {
+                pixelValues
+            } else {
+                fatalError("Gemma4 VisionModel expects rank-3 or rank-4 pixels")
+            }
+
+        let batch = inputs.dim(0)
+        let height = inputs.dim(2)
+        let width = inputs.dim(3)
+        let (basePositions, basePadding, realPatchCount) = patchPositionsSingle(height: height, width: width)
+
+        let patchPositions = broadcast(
+            basePositions.expandedDimensions(axis: 0), to: [batch, maxPatches, 2])
+        let paddingPositions = broadcast(
+            basePadding.expandedDimensions(axis: 0), to: [batch, maxPatches])
+
+        var inputEmbeds = patchEmbedder(
+            inputs,
+            patchPositions: patchPositions[0..., ..<realPatchCount, 0...],
+            paddingPositions: paddingPositions[0..., ..<realPatchCount]
+        )
+
+        let numPadding = maxPatches - realPatchCount
+        if numPadding > 0 {
+            let padded = MLXArray.zeros(
+                [batch, numPadding, inputEmbeds.dim(-1)], dtype: inputEmbeds.dtype)
+            inputEmbeds = concatenated([inputEmbeds, padded], axis: 1)
+        }
+
+        let validMask = paddingPositions .== MLXArray(false)
+        var attentionMask =
+            expandedDimensions(validMask, axis: 1).asType(inputEmbeds.dtype)
+            * expandedDimensions(validMask, axis: 2).asType(inputEmbeds.dtype)
+        attentionMask = MLX.where(
+            attentionMask .== MLXArray(1, dtype: inputEmbeds.dtype),
+            MLXArray(0.0, dtype: inputEmbeds.dtype),
+            MLXArray(-Float.infinity, dtype: inputEmbeds.dtype)
+        )
+        attentionMask = expandedDimensions(attentionMask, axis: 1)
+
+        var hiddenStates = encoder(inputEmbeds, positions: patchPositions, mask: attentionMask)
+        let (pooled, pooledMask) = pooler(
+            hiddenStates, patchPositions: patchPositions, paddingPositions: paddingPositions)
+
+        var realStates: [MLXArray] = []
+        realStates.reserveCapacity(batch)
+        for batchIndex in 0 ..< batch {
+            let validCount = pooledMask[batchIndex, 0...].asType(.int32).sum().item(Int.self)
+            realStates.append(pooled[batchIndex, ..<validCount, 0...])
+        }
+
+        hiddenStates = concatenated(realStates, axis: 0)[.newAxis, 0..., 0...]
+
+        if config.standardize {
+            hiddenStates = (hiddenStates - stdBias) * stdScale
+        }
+
+        return hiddenStates
+    }
+}
+
+// MARK: - Multimodal
+
+public final class Gemma4MultimodalEmbedder: Module {
+    @ModuleInfo(key: "embedding_projection") var embeddingProjection: Linear
+    @ModuleInfo(key: "embedding_pre_projection_norm") var embeddingPreProjectionNorm:
+        Gemma4VisionRMSNormNoScale
+
+    public init(embeddingDim: Int, textHiddenSize: Int, eps: Float = 1e-6) {
+        self._embeddingProjection.wrappedValue = Linear(
+            embeddingDim, textHiddenSize, bias: false)
+        self._embeddingPreProjectionNorm.wrappedValue = Gemma4VisionRMSNormNoScale(eps: eps)
+        super.init()
+    }
+
+    public func callAsFunction(_ inputsEmbeds: MLXArray) -> MLXArray {
+        embeddingProjection(embeddingPreProjectionNorm(inputsEmbeds))
+    }
+}
+
+public func maskedScatter(
+    inputTensor: MLXArray, mask: MLXArray, source: MLXArray
+) throws -> MLXArray {
+    let originalShape = inputTensor.shape
+    let flattenedInput = inputTensor.flattened()
+    let flattenedSource = source.flattened()
+    let flattenedMask = mask.flattened()
+
+    let indices = flattenedMask.asType(.bool).asArray(Bool.self).enumerated().compactMap {
+        index, value in
+        value ? UInt32(index) : nil
+    }
+
+    guard indices.count == flattenedSource.size else {
+        throw Gemma4VLMError.featureTokenMismatch(
+            expected: indices.count / max(1, inputTensor.dim(-1)),
+            actual: max(1, flattenedSource.size / max(1, inputTensor.dim(-1))))
+    }
+
+    var result = flattenedInput
+    if !indices.isEmpty {
+        result[MLXArray(indices)] = flattenedSource
+    }
+    return result.reshaped(originalShape)
+}
