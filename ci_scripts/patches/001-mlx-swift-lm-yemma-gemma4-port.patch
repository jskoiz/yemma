+        }
+    }
+
+    func testUpdateAllowsMissingDerivedPerLayerProjectionScale() throws {
+        try assertUpdateAllowsMissingDerivedKey { key in
+            !key.hasSuffix("perLayerProjectionScale")
+        }
+    }
