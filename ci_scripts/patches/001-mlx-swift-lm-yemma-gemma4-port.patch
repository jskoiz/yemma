+    private static func defaultRopeParameters() -> [String: [String: StringOrNumber]] {
+        [
+            "full_attention": [
+                "partial_rotary_factor": .float(0.25),
+                "rope_theta": .float(1_000_000.0),
+                "rope_type": .string("proportional"),
+            ],
+            "sliding_attention": [
+                "partial_rotary_factor": .float(1.0),
+                "rope_theta": .float(10_000.0),
+                "rope_type": .string("default"),
+            ],
+        ]
+    }
+
+    private static func defaultLayerTypes(
+        numHiddenLayers: Int,
+        slidingWindowPattern: Int
+    ) -> [String] {
+        let localCount = max(slidingWindowPattern - 1, 0)
+        let pattern = Array(repeating: "sliding_attention", count: localCount) + ["full_attention"]
+        guard !pattern.isEmpty else {
+            return Array(repeating: "full_attention", count: numHiddenLayers)
+        }
+
+        var result: [String] = []
+        result.reserveCapacity(numHiddenLayers)
+        while result.count < numHiddenLayers {
+            result.append(contentsOf: pattern)
+        }
+        return Array(result.prefix(numHiddenLayers))
+    }
+}
