+
+    func callAsFunction(_ x: MLXArray) -> MLXArray {
+        MLXFast.rmsNorm(x, weight: weight, eps: eps)
+    }
+}
+
+func gemma4OneHot(_ indices: MLXArray, numClasses: Int) -> MLXArray {
+    let classes = MLXArray(0 ..< numClasses).asType(.int32)
+    return (expandedDimensions(indices.asType(.int32), axis: -1) .== classes).asType(.float32)
+}
+
+func gemma4RotateHalf(_ x: MLXArray) -> MLXArray {
+    let half = x.dim(-1) / 2
+    let first = x[.ellipsis, ..<half]
+    let second = x[.ellipsis, half...]
+    return concatenated([-second, first], axis: -1)
+}
+
+func applyGemma4MultidimensionalRoPE(
+    _ inputs: MLXArray, positions: MLXArray, baseFrequency: Float = 100.0
+) -> MLXArray {
+    let headDim = inputs.dim(-1)
+
+    if positions.ndim == 2 {
+        let half = headDim / 2
+        let freqExponents =
+            (2.0 / Float(headDim)) * MLXArray(0 ..< half).asType(.float32)
+        let timescale = MLX.pow(baseFrequency, freqExponents)
+        var sinusoid = positions.asType(.float32)[0..., 0..., .newAxis] / timescale
+        let cosVal = concatenated([cos(sinusoid), cos(sinusoid)], axis: -1).asType(inputs.dtype)
+        let sinVal = concatenated([sin(sinusoid), sin(sinusoid)], axis: -1).asType(inputs.dtype)
+        return inputs * cosVal[0..., 0..., .newAxis, 0...]
+            + gemma4RotateHalf(inputs) * sinVal[0..., 0..., .newAxis, 0...]
+    }
+
+    let dimensions = positions.dim(-1)
+    let channelsPerDimension = 2 * (headDim / (2 * dimensions))
+    let halfPerDimension = channelsPerDimension / 2
+
+    var parts: [MLXArray] = []
+    parts.reserveCapacity(dimensions)
+
+    for index in 0 ..< dimensions {
+        let start = index * channelsPerDimension
+        let end = start + channelsPerDimension
+        let xPart = inputs[.ellipsis, start ..< end]
+        let freqExponents =
+            (2.0 / Float(channelsPerDimension)) * MLXArray(0 ..< halfPerDimension).asType(.float32)
+        let timescale = MLX.pow(baseFrequency, freqExponents)
+        let positionSlice = positions[0..., 0..., index].asType(.float32)[0..., 0..., .newAxis]
+        let sinusoid = positionSlice / timescale
+        let cosVal = concatenated([cos(sinusoid), cos(sinusoid)], axis: -1).asType(inputs.dtype)
+        let sinVal = concatenated([sin(sinusoid), sin(sinusoid)], axis: -1).asType(inputs.dtype)
+        let rotated = xPart * cosVal[0..., 0..., .newAxis, 0...]
+            + gemma4RotateHalf(xPart) * sinVal[0..., 0..., .newAxis, 0...]
+        parts.append(rotated)
+    }
+
+    return concatenated(parts, axis: -1)
+}
