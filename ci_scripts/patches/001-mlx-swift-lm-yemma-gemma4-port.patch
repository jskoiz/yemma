+// Copyright © 2026 Apple Inc.
+
+import MLXLMCommon
+import MLXVLM
+import XCTest
+
+final class Gemma4ConfigTests: XCTestCase {
+
+    func testBaseConfigurationDecodesGemma4QuantizationOverrides() throws {
+        let configuration = try JSONDecoder.json5().decode(
+            BaseConfiguration.self,
+            from: Gemma4ConfigFixtures.configData
+        )
+
+        XCTAssertEqual(configuration.modelType, "gemma4")
+        XCTAssertEqual(configuration.eosTokenIds?.values, [1, 106, 50])
+        let defaultQuantization = try XCTUnwrap(configuration.perLayerQuantization?.quantization)
+        XCTAssertEqual(defaultQuantization.groupSize, 64)
+        XCTAssertEqual(defaultQuantization.bits, 4)
+        XCTAssertEqual(defaultQuantization.mode, .affine)
+
+        let overrideQuantization = try XCTUnwrap(
+            configuration.perLayerQuantization?.quantization(
+                layer: "language_model.model.layers.0.mlp.gate_proj")
+        )
+        XCTAssertEqual(overrideQuantization.groupSize, 64)
+        XCTAssertEqual(overrideQuantization.bits, 8)
+    }
+
+    func testBaseProcessorConfigurationDecodesGemma4ProcessorClass() throws {
+        let configuration = try JSONDecoder.json5().decode(
+            BaseProcessorConfiguration.self,
+            from: Gemma4ConfigFixtures.processorConfigData
+        )
+
+        XCTAssertEqual(configuration.processorClass, "Gemma4Processor")
+    }
+
+    func testGemma4TextConfigurationPreservesProportionalRopeParameters() throws {
+        let configuration = try JSONDecoder.json5().decode(
+            Gemma4TextConfiguration.self,
+            from: Gemma4ConfigFixtures.configData
+        )
+
+        XCTAssertEqual(configuration.ropeParameters["full_attention"]?["rope_type"], .string("proportional"))
+        XCTAssertEqual(configuration.ropeParameters["full_attention"]?["partial_rotary_factor"], .float(0.25))
+        XCTAssertEqual(configuration.ropeParameters["sliding_attention"]?["rope_type"], .string("default"))
+    }
+
+    func testGemma4ConfigurationFallsBackToNestedTextFields() throws {
+        let configuration = try JSONDecoder.json5().decode(
+            Gemma4Configuration.self,
+            from: Gemma4ConfigFixtures.configData
+        )
+
+        XCTAssertEqual(configuration.modelType, "gemma4")
