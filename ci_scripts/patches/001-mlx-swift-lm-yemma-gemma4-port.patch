+    func testRepetitionContextFlattensRank2PromptBeforeAppendingSampledToken() {
+        var processor = RepetitionContext(repetitionPenalty: 2.0, repetitionContextSize: 5)
+        processor.prompt(MLXArray([0, 1, 2, 3, 4, 5, 6])[.newAxis, .ellipsis].asType(.int32))
+        processor.didSample(token: MLXArray([9]).asType(.int32))
+
+        let logits = MLXArray((0 ..< 10).map(Float.init))[.newAxis, .ellipsis]
+        let processed = processor.process(logits: logits)
+        let values = processed[0].asArray(Float.self)
+
+        XCTAssertEqual(values[0], 0.0, accuracy: 1e-6)
+        XCTAssertEqual(values[1], 1.0, accuracy: 1e-6)
